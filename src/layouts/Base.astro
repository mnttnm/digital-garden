---
import "../styles/global.css";
import { getLearningLogItems } from "../lib/learning-log";
import ImageLightbox from "../components/ImageLightbox.astro";
import SubscribeForm from "../components/SubscribeForm.astro";
import SubscribeToast from "../components/SubscribeToast.astro";
import { ViewTransitions } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "learning.log: project updates and discoveries from Mohit",
} = Astro.props;
const siteTitle = "Mohit Tater";
const brandTitle = "Mohit Tater - learning.log";
const base = import.meta.env.BASE_URL;
const normalizedBase = base.endsWith("/") ? base : `${base}/`;
const homeHref = normalizedBase;
const aboutHref = `${normalizedBase}about/`;
const projectsHref = `${normalizedBase}projects/`;
const resourcesHref = `${normalizedBase}resources/`;
const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const latestLogItem = (await getLearningLogItems())[0];
const lastUpdatedLabel = latestLogItem
  ? latestLogItem.date.toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    })
  : null;

function getRelativeTimeLabel(date: Date) {
  const ms = Date.now() - date.getTime();
  const day = 1000 * 60 * 60 * 24;
  const days = Math.round(ms / day);

  if (days <= 0) return "today";
  if (days === 1) return "1d ago";
  if (days < 7) return `${days}d ago`;

  const weeks = Math.round(days / 7);
  if (weeks < 5) return `${weeks}w ago`;

  const months = Math.round(days / 30);
  if (months < 12) return `${months}mo ago`;

  const years = Math.round(days / 365);
  return `${years}y ago`;
}

const lastUpdatedRelativeLabel = latestLogItem
  ? getRelativeTimeLabel(latestLogItem.date)
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | {siteTitle}</title>
    <script is:inline>
      // Apply theme immediately to prevent flash (runs before paint)
      (function applyTheme() {
        try {
          const root = document.documentElement;
          const storedAppearance =
            localStorage.getItem("learning-log-appearance") || "auto";
          const warmth = localStorage.getItem("learning-log-warmth") || "warm";
          const font = localStorage.getItem("learning-log-font") || "serif";

          // Resolve auto to actual light/dark
          const resolvedAppearance =
            storedAppearance === "auto"
              ? window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light"
              : storedAppearance;

          root.dataset.appearance = resolvedAppearance;
          root.dataset.appearanceMode = storedAppearance;
          root.dataset.warmth = warmth;
          root.dataset.font = font;
        } catch {
          // no-op: localStorage can fail in strict privacy contexts
        }
      })();

      // Preserve theme BEFORE swap to prevent flash
      document.addEventListener("astro:before-swap", function (event) {
        try {
          const storedAppearance =
            localStorage.getItem("learning-log-appearance") || "auto";
          const warmth = localStorage.getItem("learning-log-warmth") || "warm";
          const font = localStorage.getItem("learning-log-font") || "serif";

          const resolvedAppearance =
            storedAppearance === "auto"
              ? window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light"
              : storedAppearance;

          // Apply to the incoming document BEFORE it's swapped in
          const newDoc = event.newDocument;
          newDoc.documentElement.dataset.appearance = resolvedAppearance;
          newDoc.documentElement.dataset.appearanceMode = storedAppearance;
          newDoc.documentElement.dataset.warmth = warmth;
          newDoc.documentElement.dataset.font = font;
        } catch {}
      });
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteTitle}
      href={`${base}rss.xml`}
    />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <ViewTransitions />
  </head>
  <body>
    <div class="container">
      <header class="site-header">
        <div class="site-brand">
          <a href={homeHref} class="site-title">{brandTitle}</a>
          {
            lastUpdatedLabel && (
              <p class="site-updated">
                Updated {lastUpdatedLabel}
                {lastUpdatedRelativeLabel && (
                  <span class="site-updated-sep"> · </span>
                )}
                {lastUpdatedRelativeLabel}
              </p>
            )
          }
        </div>
        <div class="site-header-actions">
          <nav class="site-nav">
            <a
              href={homeHref}
              class:list={["nav-link", { active: currentPath === homeHref }]}
            >
              <span class="nav-label-full">learning.log</span>
              <span class="nav-label-short">journal</span>
            </a>
            <a
              href={projectsHref}
              class:list={[
                "nav-link",
                { active: currentPath.startsWith(projectsHref) },
              ]}
            >
              <span class="nav-label-full">projects</span>
              <span class="nav-label-short">projects</span>
            </a>
            <a
              href={resourcesHref}
              class:list={[
                "nav-link",
                { active: currentPath.startsWith(resourcesHref) },
              ]}
            >
              <span class="nav-label-full">my stack</span>
              <span class="nav-label-short">my stack</span>
            </a>
            <a
              href={aboutHref}
              class:list={["nav-link", { active: currentPath === aboutHref }]}
            >
              <span class="nav-label-full">about</span>
              <span class="nav-label-short">about me</span>
            </a>
          </nav>

          <div class="theme-controls" data-theme-controls>
            <button
              class="theme-toggle-button"
              type="button"
              aria-label="Open theme settings"
              aria-expanded="false"
              aria-controls="theme-panel"
              data-theme-toggle
            >
              <span class="theme-label-full">theme</span>
              <svg class="theme-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="4"></circle>
                <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
              </svg>
            </button>
            <section
              id="theme-panel"
              class="theme-panel"
              hidden
              data-theme-panel
              aria-label="Theme settings"
            >
              <div class="theme-row">
                <span class="theme-label">Warmth</span>
                <div
                  class="theme-swatch-group"
                  role="radiogroup"
                  aria-label="Warmth"
                >
                  <button
                    class="theme-swatch warmth-cool"
                    type="button"
                    data-warmth="cool"
                    role="radio"
                    aria-checked="false"
                    aria-label="Cool"></button>
                  <button
                    class="theme-swatch warmth-warm"
                    type="button"
                    data-warmth="warm"
                    role="radio"
                    aria-checked="true"
                    aria-label="Warm"></button>
                  <button
                    class="theme-swatch warmth-warmer"
                    type="button"
                    data-warmth="warmer"
                    role="radio"
                    aria-checked="false"
                    aria-label="Warmer"></button>
                </div>
              </div>
              <div class="theme-row">
                <span class="theme-label">Font</span>
                <div
                  class="theme-segmented"
                  role="radiogroup"
                  aria-label="Entry title font"
                >
                  <button
                    type="button"
                    data-font="serif"
                    role="radio"
                    aria-checked="true">Serif</button
                  >
                  <button
                    type="button"
                    data-font="sans"
                    role="radio"
                    aria-checked="false">Sans</button
                  >
                </div>
              </div>
              <div class="theme-row">
                <span class="theme-label">Appearance</span>
                <div
                  class="theme-segmented"
                  role="radiogroup"
                  aria-label="Appearance mode"
                >
                  <button
                    type="button"
                    data-appearance="light"
                    role="radio"
                    aria-checked="false">Light</button
                  >
                  <button
                    type="button"
                    data-appearance="dark"
                    role="radio"
                    aria-checked="false">Dark</button
                  >
                  <button
                    type="button"
                    data-appearance="auto"
                    role="radio"
                    aria-checked="true">Auto</button
                  >
                </div>
              </div>
            </section>
          </div>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-grid">
          <div class="footer-subscribe">
            <SubscribeForm variant="inline" />
          </div>
          <div class="footer-info">
            <div class="footer-contact">
              <span class="footer-label">Contact</span>
              <ul class="footer-links">
                <li><a href={`${base}rss.xml`}>RSS</a></li>
                <li><a href="https://x.com/tatermohit" target="_blank" rel="noopener">Twitter/X</a></li>
                <li><a href="https://www.linkedin.com/in/tatermohit/" target="_blank" rel="noopener">LinkedIn</a></li>
                <li><a href="https://github.com/mnttnm" target="_blank" rel="noopener">GitHub</a></li>
                <li><a href="mailto:mohittater.iiita@gmail.com">Email</a></li>
              </ul>
            </div>
            <div class="footer-bottom">
              <p class="footer-tagline">Ship small, learn lots, share openly.</p>
              <p class="footer-copyright">© {new Date().getFullYear()} Mohit Tater</p>
            </div>
          </div>
        </div>
      </footer>
    </div>

    <script>
      // Theme controls - compatible with View Transitions
      (function () {
        const root = document.documentElement;
        const STORAGE_KEYS = {
          warmth: "learning-log-warmth",
          font: "learning-log-font",
          appearance: "learning-log-appearance",
        };
        function safeGetStorage(key, fallback) {
          try {
            return localStorage.getItem(key) || fallback;
          } catch {
            return fallback;
          }
        }

        function safeSetStorage(key, value) {
          try {
            localStorage.setItem(key, value);
          } catch {}
        }
        const RUNTIME_KEY = "__learningLogThemeRuntime";
        const runtime =
          window[RUNTIME_KEY] ||
          (window[RUNTIME_KEY] = {
            globalListenersBound: false,
            state: {
              warmth: safeGetStorage(STORAGE_KEYS.warmth, "warm"),
              font: safeGetStorage(STORAGE_KEYS.font, "serif"),
              appearanceMode: safeGetStorage(
                STORAGE_KEYS.appearance,
                "auto",
              ),
            },
            systemDarkQuery: window.matchMedia(
              "(prefers-color-scheme: dark)",
            ),
          });
        const state = runtime.state;
        const systemDarkQuery = runtime.systemDarkQuery;

        function getResolvedAppearance() {
          if (state.appearanceMode === "auto") {
            return systemDarkQuery.matches ? "dark" : "light";
          }
          return state.appearanceMode;
        }

        function syncRadioButtons(selector, currentValue, attributeName) {
          document.querySelectorAll(selector).forEach((btn) => {
            const isActive = btn.getAttribute(attributeName) === currentValue;
            btn.classList.toggle("active", isActive);
            btn.setAttribute("aria-checked", String(isActive));
          });
        }

        function applyState() {
          const resolvedAppearance = getResolvedAppearance();
          root.dataset.warmth = state.warmth;
          root.dataset.font = state.font;
          root.dataset.appearance = resolvedAppearance;
          root.dataset.appearanceMode = state.appearanceMode;

          syncRadioButtons("[data-warmth]", state.warmth, "data-warmth");
          syncRadioButtons("[data-font]", state.font, "data-font");
          syncRadioButtons(
            "button[data-appearance]",
            state.appearanceMode,
            "data-appearance",
          );
        }

        function persistState() {
          safeSetStorage(STORAGE_KEYS.warmth, state.warmth);
          safeSetStorage(STORAGE_KEYS.font, state.font);
          safeSetStorage(STORAGE_KEYS.appearance, state.appearanceMode);
        }

        function setPanelOpen(open) {
          const panel = document.querySelector("[data-theme-panel]");
          const toggle = document.querySelector("[data-theme-toggle]");
          if (!panel || !toggle) return;

          if (open) {
            panel.hidden = false;
            requestAnimationFrame(() => panel.classList.add("open"));
          } else {
            panel.hidden = true;
            panel.classList.remove("open");
          }
          toggle.setAttribute("aria-expanded", String(open));
        }

        if (!runtime.globalListenersBound) {
          systemDarkQuery.addEventListener("change", () => {
            if (state.appearanceMode === "auto") {
              applyState();
            }
          });

          document.addEventListener("click", (event) => {
            const panel = document.querySelector("[data-theme-panel]");
            const controls = document.querySelector("[data-theme-controls]");
            const target = event.target;
            if (!(target instanceof Element) || !controls || !panel) return;

            const toggleTrigger = target.closest("[data-theme-toggle]");
            if (toggleTrigger) {
              event.preventDefault();
              setPanelOpen(
                panel.hidden || !panel.classList.contains("open"),
              );
              return;
            }

            const warmthButton = target.closest("[data-warmth]");
            if (warmthButton) {
              state.warmth =
                warmthButton.getAttribute("data-warmth") || "warm";
              applyState();
              persistState();
              return;
            }

            const fontButton = target.closest("[data-font]");
            if (fontButton) {
              state.font = fontButton.getAttribute("data-font") || "serif";
              applyState();
              persistState();
              return;
            }

            const appearanceButton = target.closest("button[data-appearance]");
            if (appearanceButton) {
              state.appearanceMode =
                appearanceButton.getAttribute("data-appearance") || "auto";
              applyState();
              persistState();
              return;
            }

            if (!panel.hidden && !controls.contains(target)) {
              setPanelOpen(false);
            }
          });

          document.addEventListener("keydown", (event) => {
            if (event.key !== "Escape") return;
            const panel = document.querySelector("[data-theme-panel]");
            const toggle = document.querySelector("[data-theme-toggle]");
            if (panel && !panel.hidden) {
              setPanelOpen(false);
              toggle?.focus();
            }
          });

          runtime.globalListenersBound = true;
        }

        // Setup element listeners (called on each page load)
        function setupControls() {
          const toggle = document.querySelector("[data-theme-toggle]");
          const panel = document.querySelector("[data-theme-panel]");

          if (!toggle || !panel) return;

          applyState();
          setPanelOpen(false);
        }

        // Initial setup
        setupControls();

        // Re-setup after View Transitions
        document.addEventListener("astro:page-load", setupControls);
      })();
    </script>

    <ImageLightbox />
    <SubscribeToast />

    <!-- Back to Top Button -->
    <button
      id="back-to-top"
      class="back-to-top"
      type="button"
      aria-label="Back to top"
      hidden
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>

    <script>
      // Swipe navigation between pages
      (function setupSwipeNavigation() {
        const NAV_ORDER = ['/', '/projects/', '/resources/', '/about/'];
        const SWIPE_THRESHOLD = 80;
        const SWIPE_VELOCITY_THRESHOLD = 0.3;

        let touchStartX = 0;
        let touchStartY = 0;
        let touchStartTime = 0;
        let isSwiping = false;

        function getCurrentPageIndex() {
          const path = window.location.pathname;
          // Exact match first
          const exactIndex = NAV_ORDER.indexOf(path);
          if (exactIndex !== -1) return exactIndex;

          // Check if path starts with any nav item (for nested pages)
          for (let i = NAV_ORDER.length - 1; i >= 0; i--) {
            if (NAV_ORDER[i] !== '/' && path.startsWith(NAV_ORDER[i])) {
              return i;
            }
          }
          return 0; // Default to home
        }

        function navigateTo(index: number) {
          if (index < 0 || index >= NAV_ORDER.length) return;
          const targetPath = NAV_ORDER[index];
          if (window.location.pathname !== targetPath) {
            window.location.href = targetPath;
          }
        }

        function handleTouchStart(e: TouchEvent) {
          if (e.touches.length !== 1) return;

          // Don't interfere with scrollable elements
          const target = e.target as HTMLElement;
          if (target.closest('.entry-thumbnails, .code-block, pre, .theme-panel')) return;

          touchStartX = e.touches[0].clientX;
          touchStartY = e.touches[0].clientY;
          touchStartTime = Date.now();
          isSwiping = true;
        }

        function handleTouchMove(e: TouchEvent) {
          if (!isSwiping || e.touches.length !== 1) return;

          const deltaX = e.touches[0].clientX - touchStartX;
          const deltaY = e.touches[0].clientY - touchStartY;

          // If vertical scroll is dominant, cancel swipe detection
          if (Math.abs(deltaY) > Math.abs(deltaX) * 1.5) {
            isSwiping = false;
          }
        }

        function handleTouchEnd(e: TouchEvent) {
          if (!isSwiping) return;
          isSwiping = false;

          const touchEndX = e.changedTouches[0].clientX;
          const deltaX = touchEndX - touchStartX;
          const deltaTime = Date.now() - touchStartTime;
          const velocity = Math.abs(deltaX) / deltaTime;

          // Check if swipe meets thresholds
          if (Math.abs(deltaX) < SWIPE_THRESHOLD && velocity < SWIPE_VELOCITY_THRESHOLD) return;

          const currentIndex = getCurrentPageIndex();

          if (deltaX > 0) {
            // Swipe right → go to previous page
            navigateTo(currentIndex - 1);
          } else {
            // Swipe left → go to next page
            navigateTo(currentIndex + 1);
          }
        }

        // Only enable on touch devices
        if ('ontouchstart' in window) {
          document.addEventListener('touchstart', handleTouchStart, { passive: true });
          document.addEventListener('touchmove', handleTouchMove, { passive: true });
          document.addEventListener('touchend', handleTouchEnd, { passive: true });
        }
      })();
    </script>

    <script>
      function setupBackToTop() {
        const btn = document.getElementById('back-to-top') as HTMLButtonElement | null;
        if (!btn) return;

        const button = btn; // TypeScript narrowing
        let ticking = false;
        const SCROLL_THRESHOLD = 400;

        function updateVisibility() {
          const shouldShow = window.scrollY > SCROLL_THRESHOLD;
          if (shouldShow && button.hidden) {
            button.hidden = false;
            requestAnimationFrame(() => button.classList.add('visible'));
          } else if (!shouldShow && !button.hidden) {
            button.classList.remove('visible');
            setTimeout(() => { button.hidden = true; }, 200);
          }
          ticking = false;
        }

        if (button.dataset.initialized === 'true') {
          updateVisibility();
          return;
        }

        button.dataset.initialized = 'true';

        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(updateVisibility);
            ticking = true;
          }
        }, { passive: true });

        button.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        // Initial check
        updateVisibility();
      }

      setupBackToTop();
      document.addEventListener('astro:page-load', setupBackToTop);
    </script>

    <style>
      .back-to-top {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 100;
        width: 2.75rem;
        height: 2.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--color-border);
        border-radius: 50%;
        background: var(--color-bg);
        color: var(--color-text-muted);
        cursor: pointer;
        opacity: 0;
        transform: translateY(1rem);
        transition: opacity 0.2s ease, transform 0.2s ease, background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
        box-shadow: 0 4px 12px -2px rgba(0, 0, 0, 0.1);
      }

      .back-to-top.visible {
        opacity: 1;
        transform: translateY(0);
      }

      .back-to-top:hover {
        background: var(--color-bg-offset);
        color: var(--color-text);
        border-color: var(--color-text-muted);
      }

      .back-to-top:active {
        transform: scale(0.95);
      }

      @media (max-width: 640px) {
        .back-to-top {
          bottom: calc(1rem + env(safe-area-inset-bottom, 0));
          right: calc(1rem + env(safe-area-inset-right, 0));
          width: 2.75rem;
          height: 2.75rem;
        }
      }
    </style>
  </body>
</html>
