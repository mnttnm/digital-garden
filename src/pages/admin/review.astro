---
/**
 * Admin Review Dashboard
 *
 * /admin/review - Lists pending captures for review and approval
 */

import Base from '../../layouts/Base.astro';
import CaptureCard from '../../components/capture/CaptureCard.astro';
import { listCaptures, getCaptureCount } from '../../lib/capture';

export const prerender = false;

// Simple auth check
const adminPassword = import.meta.env.ADMIN_PASSWORD;
const queryPassword = Astro.url.searchParams.get('password');

const isAuthenticated = adminPassword && queryPassword === adminPassword;

// If not authenticated, show login form
if (!isAuthenticated) {
  return Astro.redirect(`/admin/review?error=auth`);
}

// Load captures
type StatusType = 'pending' | 'approved' | 'published' | 'rejected';
const status = (Astro.url.searchParams.get('status') || 'pending') as StatusType;

// Parallel fetch: captures + all counts
const [captures, pending, approved, published, rejected] = await Promise.all([
  listCaptures(status, 50, 0),
  getCaptureCount('pending'),
  getCaptureCount('approved'),  // "Queued" - approved but not published
  getCaptureCount('published'),
  getCaptureCount('rejected'),
]);
const counts = { pending, approved, published, rejected };
---

<Base title="Review Captures" description="Admin dashboard for reviewing captured content">
  <div class="admin-page">
    <header class="admin-header">
      <div class="admin-title-row">
        <div class="admin-title-group">
          <h1 class="admin-title">Review Captures</h1>
          <span class="admin-badge">{counts.pending} to review</span>
          {counts.approved > 0 && (
            <span class="admin-badge queued">{counts.approved} queued</span>
          )}
        </div>

        {counts.approved > 0 && (
          <button
            type="button"
            class="publish-all-btn"
            id="publishAllBtn"
            data-count={counts.approved}
          >
            Publish All ({counts.approved})
          </button>
        )}
      </div>
      <p class="admin-subtitle">
        Review captures, then publish all queued items in a single deployment
      </p>
    </header>

    <nav class="status-tabs">
      <a
        href={`/admin/review?password=${queryPassword}&status=pending`}
        class:list={['tab', { active: status === 'pending' }]}
        data-tab="pending"
        data-count={counts.pending}
      >
        Pending (<span class="tab-count">{counts.pending}</span>)
      </a>
      <a
        href={`/admin/review?password=${queryPassword}&status=approved`}
        class:list={['tab', 'tab-queued', { active: status === 'approved' }]}
        data-tab="approved"
        data-count={counts.approved}
      >
        Queued (<span class="tab-count">{counts.approved}</span>)
      </a>
      <a
        href={`/admin/review?password=${queryPassword}&status=published`}
        class:list={['tab', { active: status === 'published' }]}
        data-tab="published"
        data-count={counts.published}
      >
        Published (<span class="tab-count">{counts.published}</span>)
      </a>
      <a
        href={`/admin/review?password=${queryPassword}&status=rejected`}
        class:list={['tab', { active: status === 'rejected' }]}
        data-tab="rejected"
        data-count={counts.rejected}
      >
        Rejected (<span class="tab-count">{counts.rejected}</span>)
      </a>
    </nav>

    {status === 'approved' && counts.approved > 0 && (
      <div class="publish-banner">
        <p>
          <strong>{counts.approved} item{counts.approved > 1 ? 's' : ''}</strong> queued for publishing.
          Click "Publish All" to deploy in a single commit.
        </p>
      </div>
    )}

    {/* Bulk selection bar */}
    {captures.length > 0 && (
      <div class="bulk-controls">
        <label class="select-all-label">
          <input type="checkbox" id="selectAll" class="select-all-checkbox" />
          <span>Select All</span>
        </label>
      </div>
    )}

    {/* Floating bulk action bar (hidden by default) */}
    <div class="bulk-action-bar hidden" id="bulkActionBar">
      <span class="bulk-count"><span id="selectedCount">0</span> selected</span>
      <div class="bulk-actions">
        {status === 'pending' && (
          <>
            <button type="button" class="bulk-btn bulk-approve" data-bulk-action="approve">
              Approve All
            </button>
            <button type="button" class="bulk-btn bulk-reject" data-bulk-action="reject">
              Reject All
            </button>
          </>
        )}
        {status === 'rejected' && (
          <button type="button" class="bulk-btn bulk-restore" data-bulk-action="restore">
            Restore All
          </button>
        )}
        {(status === 'pending' || status === 'rejected') && (
          <button type="button" class="bulk-btn bulk-delete" data-bulk-action="delete">
            Delete
          </button>
        )}
        <button type="button" class="bulk-btn bulk-clear" id="clearSelection">
          Clear
        </button>
      </div>
    </div>

    {captures.length === 0 ? (
      <div class="empty-state">
        <p class="empty-title">
          {status === 'pending' && 'No captures to review'}
          {status === 'approved' && 'No items queued'}
          {status === 'published' && 'No published items yet'}
          {status === 'rejected' && 'No rejected items'}
        </p>
        <p class="empty-subtitle">
          {status === 'pending' && 'Captures from Raycast or iOS Shortcuts will appear here'}
          {status === 'approved' && 'Approve items from Pending to queue them for publishing'}
          {status === 'published' && 'Published items will appear here after you click "Publish All"'}
          {status === 'rejected' && 'Rejected items are archived here'}
        </p>
      </div>
    ) : (
      <div class="captures-grid">
        {captures.map((capture) => (
          <CaptureCard capture={capture} adminPassword={adminPassword!} />
        ))}
      </div>
    )}
  </div>

  <script define:vars={{ adminPassword, status }}>
    // ==========================================
    // Tab Count Management
    // ==========================================
    const tabCounts = {
      pending: parseInt(document.querySelector('[data-tab="pending"]')?.dataset.count || '0'),
      approved: parseInt(document.querySelector('[data-tab="approved"]')?.dataset.count || '0'),
      published: parseInt(document.querySelector('[data-tab="published"]')?.dataset.count || '0'),
      rejected: parseInt(document.querySelector('[data-tab="rejected"]')?.dataset.count || '0'),
    };

    function updateTabCount(tabName, delta) {
      tabCounts[tabName] = Math.max(0, tabCounts[tabName] + delta);
      const tab = document.querySelector(`[data-tab="${tabName}"]`);
      if (tab) {
        const countEl = tab.querySelector('.tab-count');
        if (countEl) countEl.textContent = tabCounts[tabName];
        tab.dataset.count = tabCounts[tabName];
      }

      // Update header badges
      if (tabName === 'pending') {
        const badge = document.querySelector('.admin-badge:not(.queued)');
        if (badge) badge.textContent = `${tabCounts.pending} to review`;
      }
      if (tabName === 'approved') {
        const badge = document.querySelector('.admin-badge.queued');
        const publishBtn = document.getElementById('publishAllBtn');
        if (badge) {
          if (tabCounts.approved > 0) {
            badge.textContent = `${tabCounts.approved} queued`;
            badge.style.display = '';
          } else {
            badge.style.display = 'none';
          }
        }
        if (publishBtn) {
          if (tabCounts.approved > 0) {
            publishBtn.textContent = `Publish All (${tabCounts.approved})`;
            publishBtn.dataset.count = tabCounts.approved;
            publishBtn.style.display = '';
          } else {
            publishBtn.style.display = 'none';
          }
        }
      }
    }

    // ==========================================
    // Selection State Management
    // ==========================================
    const selectedIds = new Set();

    function updateBulkActionBar() {
      const bar = document.getElementById('bulkActionBar');
      const countEl = document.getElementById('selectedCount');
      const selectAllCheckbox = document.getElementById('selectAll');

      if (selectedIds.size > 0) {
        bar.classList.remove('hidden');
        countEl.textContent = selectedIds.size;
      } else {
        bar.classList.add('hidden');
      }

      // Update select all checkbox state
      const allCheckboxes = document.querySelectorAll('.capture-checkbox');
      const allChecked = allCheckboxes.length > 0 &&
        Array.from(allCheckboxes).every(cb => cb.checked);
      const someChecked = selectedIds.size > 0;

      selectAllCheckbox.checked = allChecked;
      selectAllCheckbox.indeterminate = someChecked && !allChecked;
    }

    function toggleCardSelection(card, checked) {
      const captureId = card.dataset.captureId;
      const checkbox = card.querySelector('.capture-checkbox');

      if (checked) {
        selectedIds.add(captureId);
        card.classList.add('selected');
        checkbox.checked = true;
      } else {
        selectedIds.delete(captureId);
        card.classList.remove('selected');
        checkbox.checked = false;
      }

      updateBulkActionBar();
    }

    // ==========================================
    // Dirty State (Unsaved Changes) Tracking
    // ==========================================
    function markCardDirty(card, isDirty) {
      const saveBtn = card.querySelector('[data-action="save"]');

      if (isDirty) {
        card.classList.add('dirty');
        saveBtn?.classList.remove('hidden');
      } else {
        card.classList.remove('dirty');
        saveBtn?.classList.add('hidden');
      }
    }

    function getCardFieldValues(card) {
      return {
        title: card.querySelector('[data-field="title"]')?.value || '',
        body: card.querySelector('[data-field="body"]')?.value || '',
        url: card.querySelector('[data-field="url"]')?.value || '',
        tags: getTagsFromCard(card),
        images: getImagesFromCard(card),
        collection: card.querySelector('[data-field="collection"]')?.value || '',
        noteType: card.querySelector('[data-field="noteType"]')?.value || '',
      };
    }

    function getTagsFromCard(card) {
      const tagsEditor = card.querySelector('.tags-editor');
      if (!tagsEditor) return [];

      return Array.from(tagsEditor.querySelectorAll('.editable-tag'))
        .map(el => el.dataset.tag);
    }

    function getImagesFromCard(card) {
      const imagesEditor = card.querySelector('.images-editor');
      if (!imagesEditor) return [];

      return Array.from(imagesEditor.querySelectorAll('.editable-image'))
        .map(el => {
          const img = el.querySelector('.image-preview');
          const src = img?.src || '';
          // Check if it's a base64 data URL
          if (src.startsWith('data:')) {
            return { url: '', data: src };
          }
          return { url: src };
        })
        .filter(img => img.url || img.data);
    }

    // ==========================================
    // Tags Editor
    // ==========================================
    function setupTagsEditor(card) {
      const tagsEditor = card.querySelector('.tags-editor');
      if (!tagsEditor) return;

      const tagsList = tagsEditor.querySelector('.tags-list');
      const tagInput = tagsEditor.querySelector('.tag-input');

      // Add tag on Enter
      tagInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && tagInput.value.trim()) {
          e.preventDefault();
          addTag(tagsList, tagInput.value.trim(), card);
          tagInput.value = '';
        }
      });

      // Remove tag handlers
      tagsList.addEventListener('click', (e) => {
        if (e.target.classList.contains('tag-remove')) {
          e.target.closest('.editable-tag').remove();
          markCardDirty(card, true);
        }
      });
    }

    function addTag(tagsList, tagValue, card) {
      // Normalize tag (lowercase, no special chars)
      const normalizedTag = tagValue.toLowerCase().replace(/[^a-z0-9-]/g, '');
      if (!normalizedTag) return;

      // Check if tag already exists
      const existing = tagsList.querySelector(`[data-tag="${normalizedTag}"]`);
      if (existing) return;

      const tagEl = document.createElement('span');
      tagEl.className = 'tag editable-tag';
      tagEl.dataset.tag = normalizedTag;
      tagEl.innerHTML = `#${normalizedTag}<button type="button" class="tag-remove" aria-label="Remove tag">×</button>`;

      tagsList.appendChild(tagEl);
      markCardDirty(card, true);
    }

    // ==========================================
    // Images Editor
    // ==========================================
    function setupImagesEditor(card) {
      const imagesEditor = card.querySelector('.images-editor');
      if (!imagesEditor) return;

      const imagesList = imagesEditor.querySelector('.images-list');
      const imageInput = imagesEditor.querySelector('.image-url-input');
      const addBtn = imagesEditor.querySelector('.image-add-btn');
      const dropZone = imagesEditor.querySelector('.image-drop-zone');
      const fileInput = imagesEditor.querySelector('.image-file-input');

      // Add image URL on button click
      addBtn?.addEventListener('click', () => {
        const url = imageInput.value.trim();
        if (url) {
          addImageFromUrl(imagesList, url, card);
          imageInput.value = '';
        }
      });

      // Add image URL on Enter
      imageInput?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          const url = imageInput.value.trim();
          if (url) {
            addImageFromUrl(imagesList, url, card);
            imageInput.value = '';
          }
        }
      });

      // File input change (upload)
      fileInput?.addEventListener('change', async (e) => {
        const files = e.target.files;
        if (files) {
          for (const file of files) {
            if (file.type.startsWith('image/')) {
              await addImageFromFile(imagesList, file, card);
            }
          }
          fileInput.value = ''; // Reset for next upload
        }
      });

      // Drag and drop
      dropZone?.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.classList.add('dragover');
      });

      dropZone?.addEventListener('dragleave', (e) => {
        e.preventDefault();
        dropZone.classList.remove('dragover');
      });

      dropZone?.addEventListener('drop', async (e) => {
        e.preventDefault();
        dropZone.classList.remove('dragover');
        const files = e.dataTransfer?.files;
        if (files) {
          for (const file of files) {
            if (file.type.startsWith('image/')) {
              await addImageFromFile(imagesList, file, card);
            }
          }
        }
      });

      // Paste support (on the drop zone)
      dropZone?.addEventListener('paste', async (e) => {
        const items = e.clipboardData?.items;
        if (items) {
          for (const item of items) {
            if (item.type.startsWith('image/')) {
              e.preventDefault();
              const file = item.getAsFile();
              if (file) {
                await addImageFromFile(imagesList, file, card);
              }
            }
          }
        }
      });

      // Remove image handlers
      imagesList?.addEventListener('click', (e) => {
        if (e.target.classList.contains('image-remove')) {
          e.target.closest('.editable-image').remove();
          markCardDirty(card, true);
        }
      });
    }

    function addImageFromUrl(imagesList, imageUrl, card) {
      // Basic URL validation
      if (!imageUrl.startsWith('http://') && !imageUrl.startsWith('https://') &&
          !imageUrl.startsWith('data:')) {
        return;
      }

      const imageEl = document.createElement('div');
      imageEl.className = 'editable-image';
      imageEl.innerHTML = `
        <img src="${imageUrl}" alt="Added image" class="image-preview" />
        <button type="button" class="image-remove" aria-label="Remove image">×</button>
      `;

      imagesList.appendChild(imageEl);
      markCardDirty(card, true);
    }

    async function addImageFromFile(imagesList, file, card) {
      return new Promise((resolve) => {
        const reader = new FileReader();
        reader.onload = (e) => {
          const base64 = e.target?.result;
          if (base64) {
            const imageEl = document.createElement('div');
            imageEl.className = 'editable-image';
            imageEl.dataset.isBase64 = 'true';
            imageEl.innerHTML = `
              <img src="${base64}" alt="Uploaded image" class="image-preview" />
              <button type="button" class="image-remove" aria-label="Remove image">×</button>
            `;
            imagesList.appendChild(imageEl);
            markCardDirty(card, true);
          }
          resolve();
        };
        reader.readAsDataURL(file);
      });
    }

    // ==========================================
    // API Actions
    // ==========================================
    async function performAction(captureId, action, body = null) {
      const endpoint = `/api/capture/${captureId}/${action}`;
      const options = {
        method: action === 'delete' ? 'DELETE' : 'POST',
        headers: {
          'Authorization': `Bearer ${adminPassword}`,
          'Content-Type': 'application/json',
        },
      };

      if (body) {
        options.body = JSON.stringify(body);
      }

      const response = await fetch(endpoint, options);
      return response.json();
    }

    async function saveCapture(card) {
      const captureId = card.dataset.captureId;
      const values = getCardFieldValues(card);

      const response = await fetch(`/api/capture/${captureId}/update`, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${adminPassword}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          title: values.title || undefined,
          text: values.body,
          url: values.url || undefined,
          images: values.images.length > 0 ? values.images : undefined,
          tags: values.tags,
          inferredCollection: values.collection,
          inferredNoteType: values.noteType || null,
          // Manual edits override AI refinement during publish
          publishUseRefined: false,
        }),
      });

      return response.json();
    }

    async function performBulkAction(action, ids) {
      // For restore, we need to call restore endpoint for each
      if (action === 'restore') {
        const results = await Promise.all(
          ids.map(id => performAction(id, 'restore'))
        );
        return {
          success: true,
          processed: results.filter(r => r.success).length,
          failed: [],
        };
      }

      const response = await fetch('/api/capture/bulk', {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${adminPassword}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ action, ids }),
      });

      return response.json();
    }

    // ==========================================
    // Card Removal Animation
    // ==========================================
    function removeCardWithAnimation(card) {
      card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
      card.style.opacity = '0';
      card.style.transform = 'translateY(-10px)';
      setTimeout(() => {
        card.remove();
        updateEmptyState();
        updateBulkActionBar();
      }, 300);
    }

    function updateEmptyState() {
      const cards = document.querySelectorAll('.capture-card');
      const grid = document.querySelector('.captures-grid');

      if (cards.length === 0 && grid) {
        const statusMessages = {
          pending: { title: 'All done!', subtitle: 'No more items to review' },
          approved: { title: 'All done!', subtitle: 'No items queued' },
          published: { title: 'No published items', subtitle: '' },
          rejected: { title: 'No rejected items', subtitle: '' },
        };
        const msg = statusMessages[status] || { title: 'All done!', subtitle: '' };

        grid.outerHTML = `
          <div class="empty-state">
            <p class="empty-title">${msg.title}</p>
            <p class="empty-subtitle">${msg.subtitle}</p>
          </div>
        `;

        // Hide bulk controls
        document.querySelector('.bulk-controls')?.classList.add('hidden');
      }
    }

    // ==========================================
    // Revert Fields to Display Values
    // ==========================================
    function revertFieldsToDisplay(card) {
      const displayMode = card.querySelector('.display-mode');
      if (!displayMode) return;

      // Get display values
      const titleEl = displayMode.querySelector('.display-title');
      const bodyEl = displayMode.querySelector('.display-body');
      const tagsEl = displayMode.querySelector('.display-tags');
      const collEl = displayMode.querySelector('.display-collection');
      const noteTypeEl = displayMode.querySelector('.display-note-type');

      const displayTitle = titleEl?.textContent || '';
      const displayBody = bodyEl?.textContent || '';
      const displayTags = tagsEl ?
        Array.from(tagsEl.querySelectorAll('.tag')).map(t => t.textContent.replace('#', '')) : [];
      const displayCollection = collEl?.textContent?.toLowerCase()
        .replace('til', 'til')
        .replace('note', 'notes')
        .replace('resource', 'resources') || 'notes';
      const displayNoteType = noteTypeEl?.textContent?.toLowerCase() || '';

      // Set field values
      const titleField = card.querySelector('[data-field="title"]');
      const bodyField = card.querySelector('[data-field="body"]');
      const collectionField = card.querySelector('[data-field="collection"]');
      const noteTypeField = card.querySelector('[data-field="noteType"]');
      const tagsList = card.querySelector('.tags-list');

      if (titleField) titleField.value = displayTitle;
      if (bodyField) bodyField.value = displayBody;
      if (collectionField) collectionField.value = displayCollection;
      if (noteTypeField) noteTypeField.value = displayNoteType;

      // Revert tags
      if (tagsList) {
        tagsList.innerHTML = displayTags.map(tag =>
          `<span class="tag editable-tag" data-tag="${tag}">#${tag}<button type="button" class="tag-remove" aria-label="Remove tag">×</button></span>`
        ).join('');
      }
    }

    // ==========================================
    // Update Display from Fields
    // ==========================================
    function updateDisplayFromFields(card) {
      const displayMode = card.querySelector('.display-mode');
      if (!displayMode) return;

      const values = getCardFieldValues(card);

      // Update URL display
      const captureContent = card.querySelector('.capture-content');
      let urlEl = captureContent?.querySelector('.capture-url');
      if (values.url) {
        const domain = (() => {
          try { return new URL(values.url).hostname.replace(/^www\./, ''); }
          catch { return values.url; }
        })();
        if (urlEl) {
          urlEl.href = values.url;
          urlEl.querySelector('.url-domain').textContent = domain;
        } else {
          // Create URL element if it doesn't exist
          const newUrl = document.createElement('a');
          newUrl.className = 'capture-url';
          newUrl.href = values.url;
          newUrl.target = '_blank';
          newUrl.rel = 'noopener';
          newUrl.innerHTML = `<span class="url-icon">🔗</span><span class="url-domain">${domain}</span><span class="url-arrow">↗</span>`;
          captureContent.insertBefore(newUrl, captureContent.firstChild);
        }
      } else if (urlEl) {
        urlEl.remove();
      }

      // Update title
      let titleEl = displayMode.querySelector('.display-title');
      if (values.title) {
        if (titleEl) {
          titleEl.textContent = values.title;
        } else {
          // Create title element if it doesn't exist
          const newTitle = document.createElement('h3');
          newTitle.className = 'display-title';
          newTitle.textContent = values.title;
          displayMode.insertBefore(newTitle, displayMode.firstChild);
        }
      } else if (titleEl) {
        titleEl.remove();
      }

      // Update body
      const bodyEl = displayMode.querySelector('.display-body');
      if (bodyEl) {
        bodyEl.textContent = values.body;
      }

      // Update tags
      let tagsEl = displayMode.querySelector('.display-tags');
      if (values.tags.length > 0) {
        const tagsHtml = values.tags.map(tag => `<span class="tag">#${tag}</span>`).join('');
        if (tagsEl) {
          tagsEl.innerHTML = tagsHtml;
        } else {
          const newTags = document.createElement('div');
          newTags.className = 'display-tags';
          newTags.innerHTML = tagsHtml;
          // Insert before classification
          const classEl = displayMode.querySelector('.display-classification');
          if (classEl) {
            displayMode.insertBefore(newTags, classEl);
          } else {
            displayMode.appendChild(newTags);
          }
        }
      } else if (tagsEl) {
        tagsEl.remove();
      }

      // Update classification
      const classEl = displayMode.querySelector('.display-classification');
      if (classEl && values.collection) {
        const collLabel = values.collection === 'til' ? 'TIL' :
          values.collection === 'resources' ? 'Resource' : 'Note';
        const collEl = classEl.querySelector('.display-collection');
        if (collEl) collEl.textContent = collLabel;

        let noteTypeEl = classEl.querySelector('.display-note-type');
        if (values.noteType) {
          const noteLabel = values.noteType === 'link' ? 'Link' :
            values.noteType === 'thought' ? 'Thought' :
            values.noteType === 'essay' ? 'Essay' :
            values.noteType === 'snippet' ? 'Snippet' : values.noteType;
          if (noteTypeEl) {
            noteTypeEl.textContent = noteLabel;
          } else {
            noteTypeEl = document.createElement('span');
            noteTypeEl.className = 'display-note-type';
            noteTypeEl.textContent = noteLabel;
            classEl.appendChild(noteTypeEl);
          }
        } else if (noteTypeEl) {
          noteTypeEl.remove();
        }
      }
    }

    // ==========================================
    // Reset to Raw
    // ==========================================
    function resetToRaw(card) {
      const rawText = card.dataset.rawText || '';
      const rawTags = JSON.parse(card.dataset.rawTags || '[]');
      const rawCollection = card.dataset.rawCollection || 'notes';
      const rawNoteType = card.dataset.rawNoteType || '';

      // Update fields
      const titleField = card.querySelector('[data-field="title"]');
      const bodyField = card.querySelector('[data-field="body"]');
      const collectionField = card.querySelector('[data-field="collection"]');
      const noteTypeField = card.querySelector('[data-field="noteType"]');
      const tagsList = card.querySelector('.tags-list');

      if (titleField) titleField.value = '';
      if (bodyField) bodyField.value = rawText;
      if (collectionField) collectionField.value = rawCollection;
      if (noteTypeField) noteTypeField.value = rawNoteType;

      // Reset tags
      if (tagsList) {
        tagsList.innerHTML = rawTags.map(tag =>
          `<span class="tag editable-tag" data-tag="${tag}">#${tag}<button type="button" class="tag-remove" aria-label="Remove tag">×</button></span>`
        ).join('');
      }

      // Remove refined badge
      card.querySelector('.refined-badge')?.remove();
      card.dataset.hasRefined = 'false';

      // Hide reset button
      card.querySelector('[data-action="reset"]')?.classList.add('hidden');

      markCardDirty(card, true);
    }

    // ==========================================
    // Event Handlers Setup
    // ==========================================

    // Publish All button
    const publishBtn = document.getElementById('publishAllBtn');
    if (publishBtn) {
      publishBtn.addEventListener('click', async () => {
        const count = publishBtn.dataset.count;
        if (!confirm(`Publish ${count} item(s)? This will create one GitHub commit and trigger a Vercel deployment.`)) {
          return;
        }

        publishBtn.disabled = true;
        publishBtn.textContent = 'Publishing...';

        try {
          const response = await fetch('/api/capture/publish-all', {
            method: 'POST',
            headers: {
              'Authorization': `Bearer ${adminPassword}`,
            },
          });

          const data = await response.json();

          if (response.ok) {
            alert(`Success! Published ${data.published} items.\nCommit: ${data.commit?.slice(0, 7) || 'N/A'}`);
            location.reload();
          } else {
            alert(`Error: ${data.error || 'Unknown error'}\n${data.details || ''}`);
            publishBtn.disabled = false;
            publishBtn.textContent = `Publish All (${count})`;
          }
        } catch (error) {
          console.error('Publish failed:', error);
          alert('Publish failed. Please try again.');
          publishBtn.disabled = false;
          publishBtn.textContent = `Publish All (${count})`;
        }
      });
    }

    // Select All checkbox
    const selectAllCheckbox = document.getElementById('selectAll');
    if (selectAllCheckbox) {
      selectAllCheckbox.addEventListener('change', () => {
        const cards = document.querySelectorAll('.capture-card');
        cards.forEach(card => toggleCardSelection(card, selectAllCheckbox.checked));
      });
    }

    // Clear selection button
    const clearBtn = document.getElementById('clearSelection');
    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        const cards = document.querySelectorAll('.capture-card');
        cards.forEach(card => toggleCardSelection(card, false));
      });
    }

    // Bulk action buttons
    document.querySelectorAll('[data-bulk-action]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const action = btn.dataset.bulkAction;
        const ids = Array.from(selectedIds);

        if (ids.length === 0) return;

        // Confirmation for destructive actions
        if (action === 'delete') {
          if (!confirm(`Permanently delete ${ids.length} capture(s)? This cannot be undone.`)) {
            return;
          }
        }

        btn.disabled = true;
        const originalText = btn.textContent;
        btn.textContent = 'Processing...';

        try {
          const result = await performBulkAction(action, ids);

          if (result.success || result.processed > 0) {
            const successCount = result.processed || ids.length - (result.failed?.length || 0);

            // Remove processed cards
            ids.forEach(id => {
              const card = document.querySelector(`[data-capture-id="${id}"]`);
              if (card && !result.failed?.includes(id)) {
                selectedIds.delete(id);
                removeCardWithAnimation(card);
              }
            });

            // Update tab counts based on action and current status
            if (status === 'pending') {
              updateTabCount('pending', -successCount);
              if (action === 'approve') updateTabCount('approved', successCount);
              if (action === 'reject') updateTabCount('rejected', successCount);
            } else if (status === 'rejected') {
              updateTabCount('rejected', -successCount);
              if (action === 'restore') updateTabCount('pending', successCount);
            }

            if (result.failed?.length > 0) {
              alert(`Processed ${result.processed} of ${ids.length}. ${result.failed.length} failed.`);
            }
          } else {
            alert(`Error: ${result.error || 'Unknown error'}`);
          }
        } catch (error) {
          console.error('Bulk action failed:', error);
          alert('Bulk action failed. Please try again.');
        } finally {
          btn.disabled = false;
          btn.textContent = originalText;
        }
      });
    });

    // Individual card interactions
    document.querySelectorAll('.capture-card').forEach((card) => {
      const captureId = card.dataset.captureId;

      // Setup tags editor
      setupTagsEditor(card);

      // Setup images editor
      setupImagesEditor(card);

      // Checkbox selection
      const checkbox = card.querySelector('.capture-checkbox');
      if (checkbox) {
        checkbox.addEventListener('change', () => {
          toggleCardSelection(card, checkbox.checked);
        });
      }

      // Track dirty state on field changes
      const fields = card.querySelectorAll('[data-field]');
      fields.forEach(field => {
        const event = field.tagName === 'SELECT' ? 'change' : 'input';
        field.addEventListener(event, () => markCardDirty(card, true));
      });

      // Action button handling
      card.querySelectorAll('[data-action]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const action = btn.dataset.action;

          // Handle edit mode toggle
          if (action === 'enter-edit') {
            card.dataset.editMode = 'true';
            return;
          }

          if (action === 'exit-edit') {
            // Revert any unsaved changes
            revertFieldsToDisplay(card);
            card.dataset.editMode = 'false';
            markCardDirty(card, false);
            return;
          }

          // Handle reset to raw locally
          if (action === 'reset') {
            resetToRaw(card);
            return;
          }

          // Handle save
          if (action === 'save') {
            card.classList.add('loading');
            try {
              const result = await saveCapture(card);
              if (result.success) {
                markCardDirty(card, false);
                // Update display values and exit edit mode
                updateDisplayFromFields(card);
                card.dataset.editMode = 'false';
              } else {
                alert(`Error: ${result.error || 'Failed to save'}`);
              }
            } catch (error) {
              console.error('Save failed:', error);
              alert('Save failed. Please try again.');
            } finally {
              card.classList.remove('loading');
            }
            return;
          }

          // Handle delete with confirmation
          if (action === 'delete') {
            if (!confirm('Permanently delete this capture? This cannot be undone.')) {
              return;
            }
          }

          card.classList.add('loading');

          try {
            // For approve, save any pending changes first
            if (action === 'approve') {
              const isDirty = card.classList.contains('dirty');
              if (isDirty) {
                const saveResult = await saveCapture(card);
                if (!saveResult.success) {
                  alert(`Error saving changes: ${saveResult.error}`);
                  card.classList.remove('loading');
                  return;
                }
              }
            }

            const data = await performAction(captureId, action);

            if (data.success || data.refined) {
              if (action === 'refine' && data.refined) {
                // Update fields with refined content
                const titleField = card.querySelector('[data-field="title"]');
                const bodyField = card.querySelector('[data-field="body"]');
                const tagsList = card.querySelector('.tags-list');
                const collectionField = card.querySelector('[data-field="collection"]');
                const noteTypeField = card.querySelector('[data-field="noteType"]');

                if (titleField) titleField.value = data.refined.title || '';
                if (bodyField) bodyField.value = data.refined.body || '';
                if (collectionField && data.refined.suggestedType) {
                  collectionField.value = data.refined.suggestedType;
                }
                if (noteTypeField && data.refined.suggestedNoteType) {
                  noteTypeField.value = data.refined.suggestedNoteType;
                }

                // Update tags
                if (tagsList && data.refined.suggestedTags) {
                  tagsList.innerHTML = data.refined.suggestedTags.map(tag =>
                    `<span class="tag editable-tag" data-tag="${tag}">#${tag}<button type="button" class="tag-remove" aria-label="Remove tag">×</button></span>`
                  ).join('');
                }

                // Add refined badge if not present
                if (!card.querySelector('.refined-badge')) {
                  const header = card.querySelector('.capture-header');
                  const badge = document.createElement('span');
                  badge.className = 'refined-badge';
                  badge.textContent = 'Refined';
                  header.appendChild(badge);
                }

                // Show reset button
                let resetBtn = card.querySelector('[data-action="reset"]');
                if (!resetBtn) {
                  // Create reset button if it doesn't exist
                  const actionGroup = card.querySelector('.action-group-left');
                  resetBtn = document.createElement('button');
                  resetBtn.type = 'button';
                  resetBtn.className = 'action-btn action-reset';
                  resetBtn.dataset.action = 'reset';
                  resetBtn.textContent = 'Reset to Raw';
                  actionGroup.appendChild(resetBtn);

                  // Add click handler
                  resetBtn.addEventListener('click', () => resetToRaw(card));
                }
                resetBtn.classList.remove('hidden');

                card.dataset.hasRefined = 'true';
                markCardDirty(card, true);
                // Auto-enter edit mode after refine
                card.dataset.editMode = 'true';
              } else if (action === 'approve' || action === 'reject' || action === 'restore' || action === 'delete') {
                selectedIds.delete(captureId);
                removeCardWithAnimation(card);

                // Update tab counts based on action and current status
                if (status === 'pending') {
                  updateTabCount('pending', -1);
                  if (action === 'approve') updateTabCount('approved', 1);
                  if (action === 'reject') updateTabCount('rejected', 1);
                } else if (status === 'approved') {
                  updateTabCount('approved', -1);
                  if (action === 'reject') updateTabCount('rejected', 1);
                } else if (status === 'rejected') {
                  updateTabCount('rejected', -1);
                  if (action === 'restore') updateTabCount('pending', 1);
                }
              }
            } else {
              alert(`Error: ${data.error || 'Unknown error'}`);
            }
          } catch (error) {
            console.error('Action failed:', error);
            alert('Action failed. Please try again.');
          } finally {
            card.classList.remove('loading');
          }
        });
      });
    });
  </script>
</Base>

