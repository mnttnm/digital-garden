---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const discoveries = await getCollection('discoveries', ({ data }) => !data.draft);
  return discoveries.map((discovery) => ({
    params: { slug: discovery.slug },
    props: { discovery },
  }));
}

const { discovery } = Astro.props;
const { Content } = await discovery.render();

// Get all discoveries for related and prev/next
const allDiscoveries = await getCollection('discoveries', ({ data }) => !data.draft);
const currentTags = discovery.data.tags || [];

// Related discoveries based on shared tags
const relatedDiscoveries = allDiscoveries
  .filter(d => d.slug !== discovery.slug)
  .map(d => ({
    discovery: d,
    shared: (d.data.tags || []).filter(t => currentTags.includes(t)).length
  }))
  .filter(item => item.shared > 0)
  .sort((a, b) => b.shared - a.shared)
  .slice(0, 3)
  .map(item => item.discovery);

// Prev/next discoveries chronologically
const sortedDiscoveries = allDiscoveries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const idx = sortedDiscoveries.findIndex(d => d.slug === discovery.slug);
const prevDiscovery = idx > 0 ? sortedDiscoveries[idx - 1] : null;
const nextDiscovery = idx < sortedDiscoveries.length - 1 ? sortedDiscoveries[idx + 1] : null;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

function getKindLabel(kind: string) {
  const labels: Record<string, string> = {
    'learning': 'Learning',
    'resource': 'Resource'
  };
  return labels[kind] || kind;
}

const base = import.meta.env.BASE_URL;
const hasImages = discovery.data.images && discovery.data.images.length > 0;
const hasVideos = discovery.data.videos && discovery.data.videos.length > 0;
---

<Base title={discovery.data.title}>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href={base}>learning.log</a>
    <span class="sep">/</span>
    <span class="current">{discovery.data.title}</span>
  </nav>

  <article>
    <header class="article-header">
      <div class="article-meta">
        <span class="discovery-kind">{getKindLabel(discovery.data.kind)}</span>
        <time datetime={discovery.data.date.toISOString()}>{formatDate(discovery.data.date)}</time>
      </div>
      <h1 class="article-title">{discovery.data.title}</h1>
      {discovery.data.url && (
        <p class="article-link">
          <a href={discovery.data.url} target="_blank" rel="noopener">
            {discovery.data.linkTitle || 'View original'} →
          </a>
        </p>
      )}
    </header>

    {hasImages && (
      <figure class="article-images">
        {discovery.data.images.map((img) => (
          <div class="image-container">
            <img src={img.src} alt={img.alt || discovery.data.title} />
            {img.caption && <figcaption>{img.caption}</figcaption>}
          </div>
        ))}
      </figure>
    )}

    {hasVideos && (
      <div class="article-videos">
        {discovery.data.videos.map((video) => (
          <figure class="video-container">
            <video controls poster={video.poster}>
              <source src={video.src} type="video/mp4" />
            </video>
            {video.caption && <figcaption>{video.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}

    <div class="article-content">
      <Content />
    </div>

    {discovery.data.code && (
      <div class="article-code">
        <pre><code class={`language-${discovery.data.codeLanguage || 'text'}`}>{discovery.data.code}</code></pre>
      </div>
    )}

    {discovery.data.tags && discovery.data.tags.length > 0 && (
      <footer class="article-footer">
        <div class="tags">
          {discovery.data.tags.map(tag => (
            <a href={`${base}?tag=${encodeURIComponent(tag)}`} class="tag">{tag}</a>
          ))}
        </div>
      </footer>
    )}
  </article>

  {relatedDiscoveries.length > 0 && (
    <section class="related" aria-label="Related discoveries">
      <span class="related-label">Related</span>
      <ul class="related-list">
        {relatedDiscoveries.map(r => (
          <li>
            <a href={`${base}discoveries/${r.slug}/`}>
              <span class="related-kind">{getKindLabel(r.data.kind)}</span>
              {r.data.title}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {(prevDiscovery || nextDiscovery) && (
    <nav class="post-nav" aria-label="Post navigation">
      <div class="nav-prev">
        {prevDiscovery && (
          <a href={`${base}discoveries/${prevDiscovery.slug}/`}>
            <span class="nav-dir">← Newer</span>
            <span class="nav-title">{prevDiscovery.data.title}</span>
          </a>
        )}
      </div>
      <div class="nav-next">
        {nextDiscovery && (
          <a href={`${base}discoveries/${nextDiscovery.slug}/`}>
            <span class="nav-dir">Older →</span>
            <span class="nav-title">{nextDiscovery.data.title}</span>
          </a>
        )}
      </div>
    </nav>
  )}

  <nav class="back-link">
    <a href={base}>← Back to learning.log</a>
  </nav>
</Base>

<style>
  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--text-tertiary);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .breadcrumb .sep {
    opacity: 0.4;
  }

  .breadcrumb .current {
    color: var(--text-secondary);
    max-width: 30ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .article-header {
    margin-bottom: 2rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .discovery-kind {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    font-weight: 500;
  }

  .article-meta time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .article-title {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .article-link {
    margin-bottom: 0;
  }

  .article-link a {
    color: var(--accent);
    text-decoration: none;
  }

  .article-link a:hover {
    text-decoration: underline;
  }

  .article-images {
    margin: 0 0 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .image-container img {
    width: 100%;
    height: auto;
    border-radius: 6px;
    border: 1px solid var(--color-border);
  }

  .image-container figcaption,
  .video-container figcaption {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    text-align: center;
    margin-top: 0.5rem;
  }

  .article-videos {
    margin: 0 0 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .video-container {
    margin: 0;
  }

  .video-container video {
    width: 100%;
    border-radius: 6px;
    border: 1px solid var(--color-border);
  }

  .article-content {
    margin-bottom: 3rem;
  }

  .article-code {
    margin-bottom: 2rem;
    background: var(--color-code-bg);
    border-radius: 6px;
    padding: 1rem;
    overflow-x: auto;
  }

  .article-code pre {
    margin: 0;
  }

  .article-code code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .article-footer {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    background: var(--color-code-bg);
    padding: 0.1rem 0.5rem;
    border-radius: 3px;
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .tag:hover {
    background: var(--accent);
    color: white;
  }

  /* Related Discoveries */
  .related {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
  }

  .related-label {
    display: block;
    font-size: 0.69rem;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 0.75rem;
  }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .related-list a {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text-secondary);
    transition: color 0.15s ease;
    font-family: var(--font-serif);
    font-size: 0.92rem;
  }

  .related-list a:hover {
    color: var(--accent);
  }

  .related-kind {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  /* Prev/Next Navigation */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
  }

  .nav-prev,
  .nav-next {
    min-width: 0;
  }

  .nav-next {
    text-align: right;
  }

  .post-nav a {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    color: var(--text-secondary);
    transition: color 0.15s ease;
  }

  .nav-next a {
    align-items: flex-end;
  }

  .post-nav a:hover {
    color: var(--accent);
  }

  .nav-dir {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
  }

  .nav-title {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    line-height: 1.35;
    max-width: 25ch;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  @media (max-width: 640px) {
    .post-nav {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .nav-next {
      text-align: left;
    }

    .nav-next a {
      align-items: flex-start;
    }
  }

  .back-link {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link a {
    font-size: 0.9rem;
  }
</style>
