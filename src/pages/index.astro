---
import Base from "../layouts/Base.astro";
import {
  getFeedItems,
  type FeedItem,
  type FeedBucket,
} from "../lib/learning-log";
import OnboardingOverlay from "../components/onboarding/OnboardingOverlay.astro";
import xAccounts from "../resources/x-accounts.json";

// Get top voices sorted by rating
const topVoices = [...xAccounts]
  .sort((a, b) => b.rating - a.rating)
  .slice(0, 6);

const ITEMS_PER_PAGE = 10;
const base = import.meta.env.BASE_URL;

const requestedPage = Number.parseInt(
  Astro.url.searchParams.get("page") ?? "1",
  10,
);
const currentPage =
  Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : 1;

const allItems = await getFeedItems();

const visibleCount = currentPage * ITEMS_PER_PAGE;
const visibleItems = allItems.slice(0, visibleCount);
const hasMore = allItems.length > visibleCount;

function formatEntryDate(date: Date) {
  return date.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}

function resolveHref(href: string, isExternal: boolean) {
  if (isExternal) return href;
  const normalized = href.startsWith("/") ? href.slice(1) : href;
  return `${base}${normalized}`;
}

function resolveInternalHref(href: string) {
  const normalized = href.startsWith("/") ? href.slice(1) : href;
  return `${base}${normalized}`;
}

function getCategoryLabel(item: FeedItem) {
  if (item.bucket === 'project-updates') {
    return 'PROJECT UPDATE';
  }
  // For discoveries, use kind
  if (item.kind === 'resource') {
    return 'RESOURCE';
  }
  return 'LEARNING';
}

function getCategoryDotClass(item: FeedItem) {
  if (item.bucket === 'project-updates') {
    return 'dot-project';
  }
  if (item.kind === 'resource') {
    return 'dot-resource';
  }
  return 'dot-learning';
}

function getTags(item: FeedItem) {
  return item.tags.slice(0, 3);
}

function getImagePreviews(item: FeedItem) {
  return item.images || [];
}
---

<Base
  title="logs"
  description="A digital journal for thoughts in progress."
>
  <OnboardingOverlay items={allItems} voices={topVoices} />

  <main class="journal-page">
    <header class="page-header content-offset">
      <h1 class="page-title">logs</h1>
      <p class="page-subtitle">What I shipped, learned, and bookmarked.</p>
    </header>

    {
      visibleItems.length === 0 ? (
        <p class="empty-state content-offset">
          No entries found for this category.
        </p>
      ) : (
        <ul class="entries" aria-label="Journal entries">
          {visibleItems.map((item, index) => {
            const previews = getImagePreviews(item);

            return (
              <li
                class="entry-item reveal"
                style={`--reveal-delay: ${Math.min(index * 42, 260)}ms;`}
              >
                <article class="entry-grid">
                  <aside class="entry-margin">
                    <time datetime={item.date.toISOString()}>
                      {formatEntryDate(item.date)}
                    </time>
                    <p class="entry-category">
                      {getCategoryLabel(item)}
                      <span
                        class:list={["entry-dot", getCategoryDotClass(item)]}
                        aria-hidden="true"
                      />
                    </p>
                    <button
                      class="share-button"
                      type="button"
                      aria-label="Share this entry"
                      data-share-url={resolveHref(item.href, item.isExternal)}
                      data-share-title={item.title}
                    >
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path>
                        <polyline points="16 6 12 2 8 6"></polyline>
                        <line x1="12" y1="2" x2="12" y2="15"></line>
                      </svg>
                    </button>
                  </aside>

                  <div class="entry-main">
                    {item.projectTitle && (
                      <a
                        class="project-label"
                        href={resolveInternalHref(
                          `/projects/${item.projectSlug}/`,
                        )}
                      >
                        {item.projectTitle}
                      </a>
                    )}

                    <h2 class="entry-title">
                      <a
                        href={resolveHref(item.href, item.isExternal)}
                        target={item.isExternal ? "_blank" : undefined}
                        rel={item.isExternal ? "noopener" : undefined}
                      >
                        {item.title}
                      </a>
                    </h2>

                    {item.video && (
                      <div class="entry-video">
                        <video
                          controls
                          preload="metadata"
                          playsinline
                          poster={item.video.poster}
                          aria-label={item.video.title}
                        >
                          <source src={item.video.src} />
                        </video>
                        {item.video.caption && (
                          <p class="entry-video-caption">{item.video.caption}</p>
                        )}
                      </div>
                    )}

                    {!item.video && previews.length > 0 && (
                      <div class="entry-thumbnails" data-lightbox-gallery>
                        {previews.slice(0, 3).map((preview, i) => {
                          const isLast = i === 2;
                          const hasMore = isLast && previews.length > 3;
                          const extraCount = previews.length - 3;

                          return (
                            <div
                              class:list={[
                                "entry-thumbnail",
                                { "has-more": hasMore },
                              ]}
                            >
                              <img
                                src={preview.src}
                                alt={preview.alt}
                                loading="lazy"
                                data-lightbox
                              />
                              {hasMore && (
                                <span class="thumbnail-more">
                                  +{extraCount}
                                </span>
                              )}
                            </div>
                          );
                        })}
                        {/* Hidden images for lightbox gallery navigation */}
                        {previews.slice(3).map((preview) => (
                          <img
                            src={preview.src}
                            alt={preview.alt}
                            class="sr-only"
                            data-lightbox
                          />
                        ))}
                      </div>
                    )}

                    <p class="entry-body">{item.crux}</p>

                    {item.linkPreview && (
                      <a
                        class:list={[
                          "link-preview",
                          {
                            "link-preview-tweet": item.linkPreview.tweetAuthor,
                          },
                        ]}
                        href={item.linkPreview.url}
                        target="_blank"
                        rel="noopener"
                        aria-label={`Open ${item.linkPreview.title}`}
                      >
                        {item.linkPreview.tweetAuthor ? (
                          <span
                            class="link-icon link-icon-x"
                            aria-hidden="true"
                          >
                            <svg
                              viewBox="0 0 24 24"
                              width="14"
                              height="14"
                              fill="currentColor"
                            >
                              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                            </svg>
                          </span>
                        ) : (
                          <span class="link-icon" aria-hidden="true">↗</span>
                        )}
                        <span class="link-domain">
                          {item.linkPreview.tweetAuthor
                            ? `@${item.linkPreview.tweetAuthor}`
                            : item.linkPreview.domain}
                        </span>
                      </a>
                    )}

                    {item.code && (
                      <div class="code-block">
                        <div class="code-block-header">
                          <span>{item.code.language}</span>
                          <span>code</span>
                        </div>
                        <pre>
                          <code>{item.code.code}</code>
                        </pre>
                      </div>
                    )}

                    {item.actionLink && (
                      <p class="entry-action">
                        <a
                          href={
                            item.actionLink.isExternal
                              ? item.actionLink.href
                              : resolveInternalHref(item.actionLink.href)
                          }
                          target={
                            item.actionLink.isExternal ? "_blank" : undefined
                          }
                          rel={
                            item.actionLink.isExternal ? "noopener" : undefined
                          }
                        >
                          {item.actionLink.label} →
                        </a>
                      </p>
                    )}

                    {getTags(item).length > 0 && (
                      <p class="entry-tags">
                        {getTags(item).map((tag, index) => (
                          <span>
                            #{tag.toUpperCase()}
                            {index < getTags(item).length - 1 && (
                              <span class="tag-dot"> • </span>
                            )}
                          </span>
                        ))}
                      </p>
                    )}

                    <div class="entry-separator" aria-hidden="true" />
                  </div>
                </article>
              </li>
            );
          })}
        </ul>
      )
    }

    <div
      class="content-offset load-more-wrap"
      data-has-more={hasMore ? "true" : "false"}
      data-current-page={currentPage}
    >
      {
        hasMore ? (
          <div class="load-more-container" data-load-more-container>
            <div class="load-more-trigger" data-load-trigger aria-hidden="true" />
            <div class="load-more-spinner" data-load-spinner aria-label="Loading more entries">
              <span class="spinner-dot" />
              <span class="spinner-dot" />
              <span class="spinner-dot" />
            </div>
            <button class="load-more-btn" type="button" data-load-more>
              <span class="btn-text">Load More</span>
            </button>
          </div>
        ) : (
          <span class="load-end">You've seen it all</span>
        )
      }
    </div>
  </main>

  <script>
    function initRevealAnimations() {
      const entries = document.querySelectorAll(".reveal:not(.visible)");
      const reducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      if (
        reducedMotion ||
        !("IntersectionObserver" in window) ||
        entries.length === 0
      ) {
        entries.forEach((entry) => entry.classList.add("visible"));
        return;
      }

      const observer = new IntersectionObserver(
        (entryList) => {
          entryList.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 },
      );

      entries.forEach((entry) => observer.observe(entry));
    }

    function initLoadMore() {
      const wrap = document.querySelector<HTMLElement>(".load-more-wrap");
      const button = document.querySelector<HTMLButtonElement>("[data-load-more]");
      const trigger = document.querySelector<HTMLElement>("[data-load-trigger]");
      const spinner = document.querySelector<HTMLElement>("[data-load-spinner]");
      const entriesList = document.querySelector(".entries");

      if (!wrap || !entriesList) return;

      // Prevent duplicate initialization
      if (wrap.dataset.initialized === "true") return;
      wrap.dataset.initialized = "true";

      let currentPage = parseInt(wrap.dataset.currentPage || "1", 10);
      let isLoading = false;
      let hasMore = wrap.dataset.hasMore === "true";

      async function loadMore() {
        if (isLoading || !hasMore) return;

        isLoading = true;
        wrap.classList.add("is-loading");
        if (button) button.disabled = true;

        try {
          const nextPage = currentPage + 1;
          const response = await fetch(`/api/feed?page=${nextPage}`);
          const data = await response.json();

          if (data.html) {
            entriesList.insertAdjacentHTML("beforeend", data.html);
            initRevealAnimations();
            initShareButtons();
          }

          currentPage = data.page;
          wrap.dataset.currentPage = String(currentPage);
          hasMore = data.hasMore;
          wrap.dataset.hasMore = String(hasMore);

          if (!hasMore) {
            wrap.innerHTML = '<span class="load-end">You\'ve seen it all</span>';
          }
        } catch (error) {
          console.error("Failed to load more entries:", error);
          // On error, keep button visible for retry
          if (button) {
            button.querySelector(".btn-text")!.textContent = "Retry";
          }
        } finally {
          isLoading = false;
          wrap.classList.remove("is-loading");
          if (button) button.disabled = false;
        }
      }

      // Auto-load via IntersectionObserver
      if (trigger && "IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting && hasMore && !isLoading) {
                loadMore();
              }
            });
          },
          {
            // Start loading when trigger is 200px from viewport bottom
            rootMargin: "0px 0px 200px 0px",
            threshold: 0,
          }
        );

        observer.observe(trigger);
      }

      // Manual button click fallback
      if (button) {
        button.addEventListener("click", loadMore);
      }
    }

    function initShareButtons() {
      document.querySelectorAll<HTMLButtonElement>('.share-button').forEach(btn => {
        if (btn.dataset.initialized === 'true') return;
        btn.dataset.initialized = 'true';

        btn.addEventListener('click', async (e) => {
          e.preventDefault();
          e.stopPropagation();

          const url = btn.dataset.shareUrl || window.location.href;
          const title = btn.dataset.shareTitle || document.title;
          const fullUrl = url.startsWith('http') ? url : `${window.location.origin}${url}`;

          // Try native share first (mobile)
          if (navigator.share) {
            try {
              await navigator.share({ title, url: fullUrl });
              return;
            } catch (err) {
              // User cancelled or share failed, fall through to copy
              if ((err as Error).name === 'AbortError') return;
            }
          }

          // Fallback: copy to clipboard
          try {
            await navigator.clipboard.writeText(fullUrl);
            btn.classList.add('copied');
            setTimeout(() => btn.classList.remove('copied'), 1500);
          } catch {
            // Last resort: prompt
            prompt('Copy this link:', fullUrl);
          }
        });
      });
    }

    // Run on initial load
    initRevealAnimations();
    initLoadMore();
    initShareButtons();

    // Re-run after View Transitions navigation
    document.addEventListener("astro:page-load", () => {
      initRevealAnimations();
      initLoadMore();
      initShareButtons();
    });
  </script>
</Base>

<style is:global>
  .journal-page {
    padding-top: clamp(0.1rem, 0.7vw, 0.42rem);
    padding-bottom: clamp(1.4rem, 2.8vw, 2.2rem);
  }

  .content-offset {
    padding-left: 0;
  }

  .page-header {
    margin-bottom: clamp(1.2rem, 2.4vw, 1.8rem);
  }

  .page-title {
    margin: 0 0 0.25rem 0;
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    font-family: var(--entry-title-font);
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--text-primary);
  }

  .page-subtitle {
    margin: 0;
    font-size: 0.88rem;
    color: var(--text-tertiary);
    letter-spacing: 0.012em;
    word-wrap: break-word;
    overflow-wrap: break-word;
    max-width: 32rem;
  }

  .entries {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .entry-item {
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 0.58s ease,
      transform 0.58s ease;
    transition-delay: var(--reveal-delay, 0ms);
    padding-bottom: clamp(1rem, 1.8vw, 1.45rem);
  }

  .entry-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .entry-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.72rem;
  }

  .entry-margin {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    flex-wrap: wrap;
    row-gap: 0.35rem;
    color: var(--text-tertiary);
  }

  .entry-margin time {
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }

  .entry-category {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
    font-size: 0.69rem;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .entry-dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
  }

  .dot-project {
    background: #94a3b8;
  }
  .dot-learning {
    background: #fbbf24;
  }
  .dot-resource {
    background: #10b981;
  }
  .dot-thought {
    background: #c084fc;
  }

  /* Share button */
  .share-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    margin-left: auto;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: transparent;
    color: var(--text-tertiary);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s ease, color 0.15s ease, background-color 0.15s ease;
    /* Touch target expansion to 44px */
    position: relative;
  }

  .share-button::before {
    content: '';
    position: absolute;
    inset: -0.375rem;
  }

  .entry-item:hover .share-button,
  .entry-item:focus-within .share-button {
    opacity: 1;
  }

  .share-button:hover {
    color: var(--text-secondary);
    background: var(--color-code-bg);
  }

  .share-button:active {
    transform: scale(0.95);
  }

  .share-button.copied {
    color: #10b981;
  }

  .share-button.copied::after {
    content: '✓';
    position: absolute;
    font-size: 0.6rem;
    top: -0.5rem;
    right: -0.25rem;
  }

  /* Always show and enlarge on mobile/touch so sharing is thumb-friendly. */
  @media (max-width: 768px), (hover: none) {
    .share-button {
      opacity: 1;
      width: 2.75rem;
      height: 2.75rem;
      border: 1px solid color-mix(in srgb, var(--border-primary) 90%, transparent);
      background: var(--bg-card);
    }
  }

  .entry-main {
    min-width: 0;
  }

  .entry-title {
    margin: 0 0 0.7rem 0;
    font-size: clamp(1.18rem, 2vw, 1.52rem);
    line-height: 1.22;
    font-family: var(--entry-title-font);
    font-weight: 500;
    letter-spacing: -0.012em;
  }

  .entry-title a {
    color: var(--text-primary);
    text-decoration: none;
  }

  .entry-title a:hover {
    color: var(--accent-hover);
  }

  .project-label {
    display: block;
    margin-bottom: 0.25rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .project-label:hover {
    color: var(--accent);
  }

  .entry-body {
    margin: 0 0 1rem 0;
    font-size: 1.02rem;
    line-height: 1.65;
    color: var(--text-secondary);
    max-width: min(78ch, 100%);
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .link-preview {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.9rem;
    padding: 0.35rem 0.6rem 0.35rem 0.5rem;
    border-radius: 0.4rem;
    background: color-mix(in srgb, var(--bg-subtle) 50%, transparent);
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.85rem;
    line-height: 1.4;
    max-width: 100%;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .link-preview:hover {
    background: var(--bg-subtle);
    color: var(--text-primary);
  }

  .link-icon {
    color: var(--text-tertiary);
    font-size: 0.75rem;
    flex-shrink: 0;
    opacity: 0.7;
  }

  .link-domain {
    color: inherit;
    font-size: 0.85rem;
  }

  .link-icon-x {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 999px;
    background: var(--text-primary);
    color: var(--bg-primary);
    opacity: 1;
  }

  .link-icon-x svg {
    display: block;
  }

  .code-block {
    border-radius: 0.7rem;
    overflow: hidden;
    border: 1px solid #2a2a2a;
    background: #1e1e1e;
    margin-bottom: 0.9rem;
  }

  .code-block-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.42rem 0.78rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #b4b4ac;
    text-transform: lowercase;
    border-bottom: 1px solid #2a2a2a;
  }

  .code-block pre {
    margin: 0;
    background: transparent;
    padding: 0.8rem;
    font-size: 0.84rem;
    line-height: 1.7;
    color: #d4d4d4;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .entry-tags {
    margin: 0;
    color: var(--text-tertiary);
    font-size: 0.69rem;
    font-weight: 500;
    letter-spacing: 0.07em;
  }

  .tag-dot {
    color: var(--text-tertiary);
  }

  .entry-video {
    margin-bottom: 1rem;
  }

  .entry-video video {
    width: 100%;
    max-width: 480px;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--border-primary);
    border-radius: 0.5rem;
    background: #000;
    display: block;
  }

  .entry-video-caption {
    margin: 0.4rem 0 0 0;
    font-size: 0.75rem;
    color: var(--text-tertiary);
    font-style: italic;
  }

  .entry-thumbnails {
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    margin-bottom: 1rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--border-primary) transparent;
    padding-bottom: 0.25rem;
    max-width: 100%;
  }

  .entry-thumbnails::-webkit-scrollbar {
    height: 4px;
  }

  .entry-thumbnails::-webkit-scrollbar-track {
    background: transparent;
  }

  .entry-thumbnails::-webkit-scrollbar-thumb {
    background: var(--border-primary);
    border-radius: 2px;
  }

  .entry-thumbnail {
    position: relative;
    display: block;
    flex-shrink: 0;
    border-radius: 0.5rem;
    background: var(--bg-card);
    overflow: hidden;
    box-shadow: inset 0 0 0 1px var(--border-primary);
    transition: box-shadow 0.2s ease;
    cursor: zoom-in;
  }

  .entry-thumbnail img {
    width: auto;
    max-width: min(300px, 70vw);
    height: auto;
    max-height: 200px;
    object-fit: contain;
    display: block;
  }

  .entry-thumbnail:hover {
    box-shadow:
      inset 0 0 0 1.5px color-mix(in srgb, var(--accent) 60%, var(--border-primary)),
      0 8px 20px -8px rgba(0, 0, 0, 0.25);
  }

  .entry-thumbnail.has-more::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    pointer-events: none;
  }

  .thumbnail-more {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1.1rem;
    font-weight: 600;
    z-index: 1;
    pointer-events: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
