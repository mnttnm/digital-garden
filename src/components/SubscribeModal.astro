---
import SubscribeForm from "./SubscribeForm.astro";
---

<div class="subscribe-modal-backdrop" data-subscribe-modal hidden>
  <div class="subscribe-modal" role="dialog" aria-modal="true" aria-label="Subscribe to updates">
    <button
      class="subscribe-modal-close"
      type="button"
      aria-label="Close subscribe dialog"
      data-subscribe-modal-close
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <SubscribeForm variant="inline" />
  </div>
</div>

<script>
  function setupSubscribeModal() {
    const modal = document.querySelector('[data-subscribe-modal]') as HTMLElement | null;
    const closeBtn = document.querySelector('[data-subscribe-modal-close]');
    const subscribeLinks = document.querySelectorAll('a[href="#subscribe"]');

    if (!modal) return;

    // Prevent re-initialization
    if (modal.dataset.initialized === 'true') return;
    modal.dataset.initialized = 'true';

    function openModal() {
      modal!.hidden = false;
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        modal!.classList.add('open');
        // Focus the email input
        const emailInput = modal!.querySelector('input[type="email"]') as HTMLInputElement;
        if (emailInput) {
          setTimeout(() => emailInput.focus(), 150);
        }
      });
    }

    function closeModal() {
      modal!.classList.remove('open');
      document.body.style.overflow = '';
      setTimeout(() => {
        modal!.hidden = true;
      }, 200);
    }

    // Open modal from subscribe links
    subscribeLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        openModal();
      });
    });

    // Close button
    closeBtn?.addEventListener('click', closeModal);

    // Click backdrop to close
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        closeModal();
      }
    });

    // Escape key to close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) {
        closeModal();
      }
    });

    // Close on successful subscription
    modal.addEventListener('submit', (e) => {
      const form = e.target as HTMLFormElement;
      // Watch for success message
      const observer = new MutationObserver((mutations) => {
        const message = form.querySelector('.form-message.success');
        if (message) {
          setTimeout(closeModal, 1500);
          observer.disconnect();
        }
      });
      observer.observe(form, { subtree: true, childList: true, attributes: true, attributeFilter: ['class'] });
    });
  }

  setupSubscribeModal();
  document.addEventListener('astro:page-load', setupSubscribeModal);
</script>

<style>
  .subscribe-modal-backdrop {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    padding: env(safe-area-inset-top, 0) env(safe-area-inset-right, 0) env(safe-area-inset-bottom, 0) env(safe-area-inset-left, 0);
  }

  .subscribe-modal-backdrop.open {
    opacity: 1;
    pointer-events: auto;
  }

  .subscribe-modal {
    position: relative;
    width: 100%;
    max-width: 540px;
    background: var(--bg-card);
    border-radius: 1rem 1rem 0 0;
    padding: 1.5rem;
    padding-top: 2.5rem;
    padding-bottom: calc(1.5rem + env(safe-area-inset-bottom, 0));
    transform: translateY(100%);
    transition: transform 0.25s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .subscribe-modal-backdrop.open .subscribe-modal {
    transform: translateY(0);
  }

  .subscribe-modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--text-tertiary);
    cursor: pointer;
    border-radius: 50%;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .subscribe-modal-close:hover {
    color: var(--text-primary);
    background: var(--bg-subtle);
  }

  /* Desktop: centered modal */
  @media (min-width: 640px) {
    .subscribe-modal-backdrop {
      align-items: center;
      padding: 2rem;
    }

    .subscribe-modal {
      border-radius: 1rem;
      padding: 2rem;
      transform: translateY(20px) scale(0.95);
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

    .subscribe-modal-backdrop.open .subscribe-modal {
      transform: translateY(0) scale(1);
    }
  }
</style>
