---
/**
 * Minimal navigation bar for the onboarding overlay.
 * Shows logo/site name on left, Skip button on right.
 */
---

<nav class="onboarding-nav">
  <button class="nav-logo" data-onboarding-skip aria-label="Skip introduction and enter site">
    learning.log
  </button>
  <button class="nav-skip" data-onboarding-skip>
    Skip <span aria-hidden="true">→</span>
  </button>
</nav>

<style>
  .onboarding-nav {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    z-index: 10;
  }

  .nav-logo {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-primary);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin: -0.5rem;
    border-radius: 0.5rem;
    transition: opacity 0.2s ease;
  }

  .nav-logo:hover {
    opacity: 0.7;
  }

  .nav-skip {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--text-secondary);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem 1rem;
    margin: -0.5rem -1rem;
    border-radius: 0.5rem;
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .nav-skip:hover {
    color: var(--text-primary);
  }

  .nav-skip:focus-visible,
  .nav-logo:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .onboarding-nav {
      padding: 1rem 1.25rem;
    }

    .nav-logo {
      font-size: 1rem;
    }

    .nav-skip {
      font-size: 0.85rem;
    }
  }
</style>
