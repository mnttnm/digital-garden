---
/**
 * Full-screen onboarding overlay for first-time visitors.
 * Two-column layout: typing text (left) + content marquee (right).
 * Handles skip/enter actions and exit transitions.
 */

import type { LearningLogItem } from "../../lib/learning-log";
import TypingText from "./TypingText.astro";
import ContentMarquee from "./ContentMarquee.astro";

interface Voice {
  display_name: string;
  username: string;
  one_liner: string;
  avatar_url: string;
}

interface Props {
  items: LearningLogItem[];
  voices?: Voice[];
}

const { items, voices = [] } = Astro.props;
---

<div
  class="onboarding-overlay"
  id="onboarding-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Welcome to learning.log"
  data-onboarding-visible="true"
  tabindex="-1"
>
  <header class="onboarding-header">
    <span class="onboarding-logo"
      >learning.log <span class="logo-author">by Mohit</span></span
    >
    <button class="onboarding-skip" type="button" data-onboarding-skip>
      Skip <span aria-hidden="true">→</span>
    </button>
  </header>

  <div class="onboarding-content">
    <div class="onboarding-left">
      <TypingText />
    </div>
    <div class="onboarding-right">
      <ContentMarquee items={items} voices={voices} />
    </div>
  </div>
</div>

<style>
  .onboarding-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: var(--bg-primary);
    opacity: 1;
    visibility: visible;
    transition:
      opacity 0.5s ease-out,
      visibility 0.5s ease-out;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .onboarding-overlay[data-onboarding-visible="false"] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .onboarding-overlay[data-exiting="true"] {
    opacity: 0;
    pointer-events: none;
  }

  .onboarding-header {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    opacity: 0;
    animation: fade-in-header 0.6s 0.3s ease forwards;
    gap: 1rem;
  }

  @keyframes fade-in-header {
    to {
      opacity: 1;
    }
  }

  .onboarding-logo {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .logo-author {
    color: var(--text-tertiary);
    font-weight: 400;
  }

  .onboarding-skip {
    border: 0;
    background: none;
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    min-height: 44px;
    padding: 0.5rem 0.75rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    cursor: pointer;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .onboarding-skip:hover {
    color: var(--text-primary);
    background: color-mix(in srgb, var(--bg-subtle) 92%, transparent);
  }

  .onboarding-skip:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent) 80%, transparent);
    outline-offset: 2px;
  }

  .onboarding-content {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 8rem;
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2rem;
    align-items: center;
    min-height: 0;
  }

  .onboarding-left {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    min-width: 0;
  }

  .onboarding-right {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    position: relative;
    height: 100%;
    max-height: 700px;
    padding-top: 1.5rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .onboarding-header {
      opacity: 1;
      animation: none;
    }
  }

  /* Tablet - reduce gap and right column width */
  @media (max-width: 900px) {
    .onboarding-content {
      gap: 4rem;
      grid-template-columns: 1fr 320px;
    }
  }

  @media (max-width: 768px) {
    .onboarding-header {
      padding: 1.25rem 1.5rem;
    }

    .onboarding-content {
      display: flex;
      flex-direction: column;
      padding: 0 1.5rem;
      gap: 1rem;
      align-items: stretch;
      padding-bottom: 1.5rem;
    }

    .onboarding-left {
      flex: 1;
      width: 100%;
    }

    .onboarding-right {
      flex-shrink: 0;
      width: calc(100% + 3rem);
      margin: 0 -1.5rem;
      padding: 0 1.5rem 1.5rem;
      height: auto;
      max-height: none;
    }
  }

  /* Small mobile */
  @media (max-width: 400px) {
    .onboarding-header {
      padding: 1rem 1rem;
    }

    .onboarding-content {
      padding: 0 1rem;
      padding-bottom: 1rem;
    }

    .onboarding-right {
      width: calc(100% + 2rem);
      margin: 0 -1rem;
      padding: 0 1rem 1rem;
    }

    .onboarding-logo {
      font-size: 0.92rem;
    }

    .onboarding-skip {
      font-size: 0.84rem;
      padding-inline: 0.6rem;
    }
  }
</style>

<script is:inline>
  (function () {
    const STORAGE_KEY = "learning-log-onboarding-seen";
    const FOCUSABLE_SELECTOR =
      'a[href], button:not([disabled]), textarea:not([disabled]), input:not([type="hidden"]):not([disabled]), select:not([disabled]), [tabindex]:not([tabindex="-1"])';

    function hasSeenOnboarding() {
      try {
        return localStorage.getItem(STORAGE_KEY) === "true";
      } catch {
        return true;
      }
    }

    function markOnboardingSeen() {
      try {
        localStorage.setItem(STORAGE_KEY, "true");
      } catch {}
    }

    function getFocusableElements(overlay) {
      return Array.prototype.slice
        .call(overlay.querySelectorAll(FOCUSABLE_SELECTOR))
        .filter(function (element) {
          return (
            element instanceof HTMLElement &&
            !element.hasAttribute("disabled") &&
            !element.hasAttribute("hidden") &&
            element.getAttribute("aria-hidden") !== "true" &&
            element.offsetParent !== null
          );
        });
    }

    function setPageState(overlay, isLocked) {
      const targets = [
        document.querySelector(".site-header"),
        overlay.nextElementSibling,
        document.querySelector(".site-footer"),
        document.getElementById("back-to-top"),
        document.getElementById("subscribe-toast"),
      ].filter(Boolean);

      targets.forEach(function (target) {
        if ("inert" in target) {
          target.inert = isLocked;
        }
        if (isLocked) {
          target.setAttribute("aria-hidden", "true");
        } else {
          target.removeAttribute("aria-hidden");
        }
      });

      document.body.style.overflow = isLocked ? "hidden" : "";
    }

    function exitOnboarding() {
      var overlay = document.getElementById("onboarding-overlay");
      if (!overlay) return;

      markOnboardingSeen();
      overlay.dataset.exiting = "true";
      setPageState(overlay, false);

      setTimeout(function () {
        overlay.dataset.onboardingVisible = "false";
        overlay.setAttribute("aria-hidden", "true");

        var nextTarget = document.querySelector(
          ".journal-page .entry-title a, .journal-page .load-more-btn, .site-nav .nav-link",
        );
        if (nextTarget instanceof HTMLElement) {
          nextTarget.focus();
        }
      }, 500);
    }

    function initOnboarding() {
      var overlay = document.getElementById("onboarding-overlay");
      if (!overlay) return;
      if (overlay.dataset.initialized === "true") return;
      overlay.dataset.initialized = "true";

      // Hide immediately if returning visitor
      if (hasSeenOnboarding()) {
        overlay.style.display = "none";
        overlay.dataset.onboardingVisible = "false";
        overlay.setAttribute("aria-hidden", "true");
        return;
      }

      var enterButton = document.getElementById("enter-button");
      var skipButtons = document.querySelectorAll("[data-onboarding-skip]");
      var firstSkipButton = skipButtons[0];

      setPageState(overlay, true);
      overlay.setAttribute("aria-hidden", "false");

      // Set up handlers
      skipButtons.forEach(function (btn) {
        btn.addEventListener("click", exitOnboarding);
      });

      if (enterButton) {
        enterButton.addEventListener("click", exitOnboarding);
      }

      if (firstSkipButton instanceof HTMLElement) {
        firstSkipButton.focus();
      } else {
        overlay.focus();
      }

      // Keep keyboard focus inside the onboarding until it is dismissed.
      document.addEventListener("keydown", function (e) {
        if (overlay.dataset.onboardingVisible !== "true") return;

        if (e.key === "Escape") {
          e.preventDefault();
          exitOnboarding();
          return;
        }

        if (e.key !== "Tab") return;

        var focusableElements = getFocusableElements(overlay);
        if (focusableElements.length === 0) {
          e.preventDefault();
          overlay.focus();
          return;
        }

        var first = focusableElements[0];
        var last = focusableElements[focusableElements.length - 1];
        var activeElement = document.activeElement;

        if (!overlay.contains(activeElement)) {
          e.preventDefault();
          first.focus();
          return;
        }

        if (e.shiftKey && activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initOnboarding);
    } else {
      initOnboarding();
    }

    document.addEventListener("astro:page-load", function () {
      if (window.location.pathname === "/") {
        initOnboarding();
      }
    });
  })();
</script>
