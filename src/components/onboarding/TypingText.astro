---
/**
 * Animated greeting text with smooth typewriter effect.
 * Cursor moves continuously through all text, character by character.
 * Words are grouped to prevent mid-word line breaks.
 */

const lines = [
  "Hey, welcome.",
  "Thanks for stopping by.",
  { text: "This is my ", highlight: "learning.log", suffix: " —" },
  "what I'm building, discovering, and figuring out.",
  "No polished essays. Just work in progress.",
  "The hope is simple.",
  "Stay a little closer to what's changing faster than we can blink",
];

const signature = "— Mohit";
const subtitle = "tinkering in public";

// Helper to render text as words (each word wrapped to prevent mid-word breaks)
function textToWords(text: string, startIndex: number = 0, highlightClass: string = '') {
  const result: { type: 'word' | 'space', chars: { char: string, index: number, highlight: string }[] }[] = [];
  let currentWord: { char: string, index: number, highlight: string }[] = [];
  let globalIndex = startIndex;

  for (const char of text) {
    if (char === ' ') {
      if (currentWord.length > 0) {
        result.push({ type: 'word', chars: currentWord });
        currentWord = [];
      }
      result.push({ type: 'space', chars: [{ char: ' ', index: globalIndex, highlight: highlightClass }] });
    } else {
      currentWord.push({ char, index: globalIndex, highlight: highlightClass });
    }
    globalIndex++;
  }
  if (currentWord.length > 0) {
    result.push({ type: 'word', chars: currentWord });
  }
  return { words: result, endIndex: globalIndex };
}
---

<div class="typing-container">
  <div class="typing-content" id="typing-content">
    {lines.map((line, lineIdx) => (
      <p class="typing-line" data-line={lineIdx}>{typeof line === 'string' ? (
          textToWords(line).words.map((segment) =>
            segment.type === 'space' ? (
              <span class="char" data-char={segment.chars[0].index}>{'\u00A0'}</span>
            ) : (
              <span class="word">{segment.chars.map((c) => (
                <span class={`char ${c.highlight}`} data-char={c.index}>{c.char}</span>
              ))}</span>
            )
          )
        ) : (
          (() => {
            const part1 = textToWords(line.text, 0);
            const part2 = textToWords(line.highlight, part1.endIndex, 'highlight');
            const part3 = textToWords(line.suffix, part2.endIndex);
            return [...part1.words, ...part2.words, ...part3.words].map((segment) =>
              segment.type === 'space' ? (
                <span class="char" data-char={segment.chars[0].index}>{'\u00A0'}</span>
              ) : (
                <span class="word">{segment.chars.map((c) => (
                  <span class={`char ${c.highlight}`} data-char={c.index}>{c.char}</span>
                ))}</span>
              )
            );
          })()
        )}</p>
    ))}
    <div class="signature-block">
      <p class="typing-line signature">{textToWords(signature).words.map((segment) =>
        segment.type === 'space' ? (
          <span class="char" data-char={segment.chars[0].index}>{'\u00A0'}</span>
        ) : (
          <span class="word">{segment.chars.map((c) => (
            <span class="char" data-char={c.index}>{c.char}</span>
          ))}</span>
        )
      )}</p>
      <p class="typing-line subtitle">{textToWords(subtitle).words.map((segment) =>
        segment.type === 'space' ? (
          <span class="char" data-char={segment.chars[0].index}>{'\u00A0'}</span>
        ) : (
          <span class="word">{segment.chars.map((c) => (
            <span class="char" data-char={c.index}>{c.char}</span>
          ))}</span>
        )
      )}</p>
    </div>
    <button class="start-reading-btn" id="enter-button" data-onboarding-enter>
      Start reading <span class="arrow" aria-hidden="true">→</span>
    </button>
  </div>
  <span class="cursor" id="typing-cursor"></span>
</div>

<style>
  .typing-container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 2rem 3rem;
    width: min(100%, 580px);
    max-width: 100%;
    min-width: 0;
    position: relative;
  }

  .typing-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    max-width: 100%;
  }

  .typing-line {
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 1.8vw, 1.18rem);
    line-height: 1.6;
    color: var(--text-primary);
    margin: 0;
    white-space: normal;
    max-width: 100%;
    overflow-wrap: break-word;
    word-break: normal;
  }

  /* Characters start invisible */
  .char {
    opacity: 0;
  }

  .char.visible {
    opacity: 1;
  }

  .char.highlight.visible {
    color: var(--accent);
    font-weight: 500;
  }

  /* Word wrapper prevents mid-word line breaks */
  .word {
    display: inline;
    white-space: nowrap;
  }

  .signature-block {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .start-reading-btn {
    margin-top: 2rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
    color: var(--bg-primary);
    background: var(--text-primary);
    border: none;
    border-radius: 0.5rem;
    padding: 0.75rem 1.4rem;
    min-height: 44px;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: all 0.2s ease;
  }

  .start-reading-btn.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .start-reading-btn:hover {
    background: var(--accent);
    transform: translateY(-1px);
  }

  .start-reading-btn .arrow {
    display: inline-block;
    margin-left: 0.4rem;
    transition: transform 0.2s ease;
  }

  .start-reading-btn:hover .arrow {
    transform: translateX(3px);
  }

  .signature .char.visible {
    color: var(--accent);
    font-style: italic;
  }

  .subtitle {
    font-size: 0.9rem;
    letter-spacing: 0.03em;
  }

  .subtitle .char.visible {
    color: var(--text-secondary);
  }

  /* Cursor - positioned absolutely, moves via JS */
  .cursor {
    position: absolute;
    width: 2px;
    height: 1.15em;
    background: var(--accent);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.1s ease;
  }

  .cursor.visible {
    opacity: 1;
  }

  .cursor.blink {
    animation: cursor-blink 0.7s step-end infinite;
  }

  @keyframes cursor-blink {
    0%,
    50% {
      opacity: 1;
    }
    51%,
    100% {
      opacity: 0;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .typing-container {
      padding: 0;
      max-width: 100%;
      width: 100%;
    }

    .typing-line {
      font-size: clamp(0.95rem, 4vw, 1.08rem);
    }
  }

  /* Small mobile (375px and below) */
  @media (max-width: 400px) {
    .typing-line {
      font-size: clamp(0.88rem, 4.2vw, 1rem);
    }

    .start-reading-btn {
      padding: 0.7rem 1.2rem;
      font-size: 0.85rem;
    }

    .signature-block {
      margin-top: 1.25rem;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .char {
      opacity: 1 !important;
    }

    .char.highlight {
      color: var(--accent);
    }

    .signature .char {
      color: var(--accent);
    }

    .subtitle .char {
      color: var(--text-secondary);
    }

    .cursor {
      display: none;
    }
  }
</style>

<script>
  function initTypingEffect() {
    const container = document.getElementById("typing-content");
    const cursor = document.getElementById("typing-cursor");

    if (!container || !cursor) return;
    if (container.dataset.initialized === "true") return;
    container.dataset.initialized = "true";

    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const startBtn = document.querySelector<HTMLButtonElement>(".start-reading-btn");

    if (reducedMotion) {
      container
        .querySelectorAll(".char")
        .forEach((c) => c.classList.add("visible"));
      if (startBtn) startBtn.classList.add("visible");
      window.dispatchEvent(new CustomEvent("typing-complete"));
      return;
    }

    const allChars = Array.from(
      container.querySelectorAll(".char"),
    ) as HTMLSpanElement[];
    let currentIndex = 0;
    const baseDelay = 32;
    const punctuationDelay = 100;

    function positionCursor(charEl: HTMLSpanElement) {
      const rect = charEl.getBoundingClientRect();
      const containerRect = container.parentElement!.getBoundingClientRect();
      cursor.style.left = `${rect.right - containerRect.left}px`;
      cursor.style.top = `${rect.top - containerRect.top}px`;
    }

    function typeNext() {
      if (currentIndex >= allChars.length) {
        cursor.classList.add("blink");
        if (startBtn) {
          setTimeout(() => startBtn.classList.add("visible"), 300);
        }
        window.dispatchEvent(new CustomEvent("typing-complete"));
        return;
      }

      const char = allChars[currentIndex];
      char.classList.add("visible");
      positionCursor(char);
      currentIndex++;

      const text = char.textContent || "";
      const isPunctuation = /[.?!]$/.test(text);
      const delay = isPunctuation ? baseDelay + punctuationDelay : baseDelay;

      setTimeout(typeNext, delay);
    }

    cursor.classList.add("visible");
    // Dispatch typing-start event immediately
    window.dispatchEvent(new CustomEvent("typing-start"));

    setTimeout(() => {
      if (allChars[0]) {
        const rect = allChars[0].getBoundingClientRect();
        const containerRect = container.parentElement!.getBoundingClientRect();
        cursor.style.left = `${rect.left - containerRect.left}px`;
        cursor.style.top = `${rect.top - containerRect.top}px`;
      }
      setTimeout(typeNext, 200);
    }, 400);
  }

  initTypingEffect();
  document.addEventListener("astro:page-load", initTypingEffect);
</script>
