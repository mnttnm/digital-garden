---
/**
 * Vertical infinite-scrolling marquee showing glimpses of site content.
 * Displays compact cards with title, crux, and category indicator.
 * Decorative only - hidden from screen readers.
 */

import type { LearningLogItem } from "../../lib/learning-log";

interface Voice {
  display_name: string;
  username: string;
  one_liner: string;
  avatar_url: string;
}

interface Props {
  items: LearningLogItem[];
  voices?: Voice[];
  speed?: number; // seconds for one full cycle
}

const { items, voices = [], speed = 40 } = Astro.props;

// Prioritize variety - show learnings/resources/thoughts more prominently
const learnings = items.filter((i) => i.bucket === "discoveries");
const projects = items.filter((i) => i.bucket === "project-updates");

// Convert top voices to marquee items format
const topVoices = voices.slice(0, 5).map((v) => ({
  title: v.display_name,
  crux: v.one_liner,
  category: "voices" as const,
  avatar: v.avatar_url,
  image: undefined as string | undefined,
}));

// Build marquee: 3 learnings, 1 voice, 1 project pattern
type MarqueeItem = {
  title: string;
  crux: string;
  category: string;
  avatar?: string;
  image?: string;
};

// Convert LearningLogItems to MarqueeItems with images
const learningMarquee: MarqueeItem[] = learnings.map((i) => ({
  title: i.title,
  crux: i.crux,
  category: i.kind === "resource" ? "resources" : "learnings",
  image: i.images?.[0]?.src,
}));

const projectMarquee: MarqueeItem[] = projects.map((i) => ({
  title: i.title,
  crux: i.crux,
  category: "projects",
  image: i.images?.[0]?.src,
}));

const marqueeItems: MarqueeItem[] = [];
let li = 0,
  vi = 0,
  pi = 0;
while (marqueeItems.length < 14) {
  // Add 3 learnings
  for (
    let i = 0;
    i < 3 && li < learningMarquee.length && marqueeItems.length < 14;
    i++
  ) {
    marqueeItems.push(learningMarquee[li++]);
  }
  // Add 1 voice
  if (vi < topVoices.length && marqueeItems.length < 14) {
    marqueeItems.push(topVoices[vi++]);
  }
  // Add 1 project (less frequent)
  if (pi < projectMarquee.length && marqueeItems.length < 14) {
    marqueeItems.push(projectMarquee[pi++]);
  }
  // Break if we've exhausted all sources
  if (
    li >= learningMarquee.length &&
    vi >= topVoices.length &&
    pi >= projectMarquee.length
  )
    break;
}

// Category to dot color mapping (matches index.astro)
const categoryColors: Record<string, string> = {
  projects: "#94a3b8",
  learnings: "#fbbf24",
  resources: "#10b981",
  thoughts: "#c084fc",
  voices: "#f472b6", // pink for voices
};
---

<div class="marquee-wrapper" aria-hidden="true">
  <p class="marquee-label">what's inside</p>
  <div class="marquee-container">
    <div class="shimmer-placeholder">
      <div class="shimmer-card"></div>
      <div class="shimmer-card"></div>
      <div class="shimmer-card"></div>
      <div class="shimmer-card"></div>
    </div>
    <div class="marquee-gradient marquee-gradient-top"></div>

    <div class="marquee-track" style={`--marquee-speed: ${speed}s`}>
      {/* First set of items */}
      {
        marqueeItems.map((item) => (
          <div
            class:list={[
              "marquee-card",
              {
                "voice-card": item.category === "voices",
                "has-image": !!item.image,
              },
            ]}
          >
            <div class="card-header">
              <span
                class="category-dot"
                style={`background: ${categoryColors[item.category] || "#94a3b8"}`}
              />
              <span class="category-label">
                {item.category === "voices" ? "voice I follow" : item.category}
              </span>
            </div>
            <div class="card-body">
              {item.avatar && (
                <img
                  src={item.avatar}
                  alt=""
                  class="voice-avatar"
                  loading="lazy"
                />
              )}
              <div class="card-text">
                <h3 class="card-title">{item.title}</h3>
                <p class="card-crux">{item.crux}</p>
              </div>
            </div>
            {item.image && (
              <div class="card-image">
                <img src={item.image} alt="" loading="lazy" />
              </div>
            )}
          </div>
        ))
      }
      {/* Duplicate for seamless loop */}
      {
        marqueeItems.map((item) => (
          <div
            class:list={[
              "marquee-card",
              {
                "voice-card": item.category === "voices",
                "has-image": !!item.image,
              },
            ]}
            aria-hidden="true"
          >
            <div class="card-header">
              <span
                class="category-dot"
                style={`background: ${categoryColors[item.category] || "#94a3b8"}`}
              />
              <span class="category-label">
                {item.category === "voices" ? "voice I follow" : item.category}
              </span>
            </div>
            <div class="card-body">
              {item.avatar && (
                <img
                  src={item.avatar}
                  alt=""
                  class="voice-avatar"
                  loading="lazy"
                />
              )}
              <div class="card-text">
                <h3 class="card-title">{item.title}</h3>
                <p class="card-crux">{item.crux}</p>
              </div>
            </div>
            {item.image && (
              <div class="card-image">
                <img src={item.image} alt="" loading="lazy" />
              </div>
            )}
          </div>
        ))
      }
    </div>

    <div class="marquee-gradient marquee-gradient-bottom"></div>
  </div>
</div>

<style>
  .marquee-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    opacity: 0;
    animation: fade-in-wrapper 0.5s 0.5s ease forwards;
  }

  @keyframes fade-in-wrapper {
    to {
      opacity: 1;
    }
  }

  .marquee-label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0;
    text-align: center;
  }

  .marquee-container {
    position: relative;
    height: 60vh;
    max-height: 640px;
    overflow: hidden;
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--bg-card) 40%, transparent);
  }

  /* Shimmer placeholder */
  .shimmer-placeholder {
    position: absolute;
    inset: 0;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    z-index: 1;
    animation: fade-out-shimmer 0.5s 3s ease forwards;
  }

  .shimmer-card {
    height: 90px;
    border-radius: 0.5rem;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--border-primary) 30%, transparent) 0%,
      color-mix(in srgb, var(--border-primary) 60%, transparent) 50%,
      color-mix(in srgb, var(--border-primary) 30%, transparent) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s ease-in-out infinite;
  }

  @keyframes shimmer {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  @keyframes fade-out-shimmer {
    to {
      opacity: 0;
      pointer-events: none;
    }
  }

  @keyframes fade-in-track {
    to {
      opacity: 1;
    }
  }

  .marquee-gradient {
    position: absolute;
    left: 0;
    right: 0;
    height: 60px;
    z-index: 2;
    pointer-events: none;
  }

  .marquee-gradient-top {
    top: 0;
    background: linear-gradient(
      to bottom,
      var(--bg-primary) 0%,
      transparent 100%
    );
  }

  .marquee-gradient-bottom {
    bottom: 0;
    background: linear-gradient(to top, var(--bg-primary) 0%, transparent 100%);
  }

  .marquee-track {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0.75rem;
    opacity: 0;
    animation:
      fade-in-track 0.6s 3s ease forwards,
      scroll-up var(--marquee-speed) 3s linear infinite;
  }

  @keyframes scroll-up {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-50%);
    }
  }

  /* Pause on hover for accessibility */
  .marquee-container:hover .marquee-track {
    animation-play-state: paused;
  }

  .marquee-card {
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    flex-shrink: 0;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .marquee-container:hover .marquee-card {
    opacity: 0.9;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.35rem;
  }

  .category-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .category-label {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-tertiary);
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0 0 0.25rem 0;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-crux {
    font-family: var(--font-serif);
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-body {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }

  .card-text {
    flex: 1;
    min-width: 0;
  }

  .voice-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 1px solid var(--border-primary);
  }

  .voice-card {
    border-color: color-mix(in srgb, #f472b6 20%, var(--border-primary));
  }

  .card-image {
    margin-top: 0.5rem;
    border-radius: 0.35rem;
    overflow: hidden;
    background: var(--bg-subtle);
  }

  .card-image img {
    width: 100%;
    height: 60px;
    object-fit: cover;
    display: block;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  .marquee-container:hover .card-image img {
    opacity: 1;
  }

  .has-image .card-crux {
    -webkit-line-clamp: 1;
  }

  /* Mobile: horizontal scroll instead of vertical marquee */
  @media (max-width: 768px) {
    .marquee-wrapper {
      gap: 0.75rem;
    }

    .marquee-label {
      text-align: left;
      padding-left: 0.25rem;
    }

    .marquee-container {
      height: auto;
      max-height: none;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      border-radius: 0.5rem;
      background: transparent;
    }

    .marquee-container::-webkit-scrollbar {
      display: none;
    }

    .shimmer-placeholder {
      display: none;
    }

    .marquee-gradient {
      display: none;
    }

    .marquee-track {
      flex-direction: row;
      gap: 0.75rem;
      padding: 0.25rem 0;
      opacity: 1;
      animation: scroll-left 6s linear infinite;
    }

    @keyframes scroll-left {
      from {
        transform: translateX(0);
      }
      to {
        transform: translateX(-50%);
      }
    }

    .marquee-card {
      min-width: 220px;
      max-width: 220px;
      padding: 0.625rem 0.75rem;
      opacity: 0.85;
      flex-shrink: 0;
    }

    .card-title {
      font-size: 0.82rem;
      -webkit-line-clamp: 1;
    }

    .card-crux {
      font-size: 0.75rem;
      -webkit-line-clamp: 1;
    }

    .card-image {
      display: none;
    }

    .voice-avatar {
      width: 1.75rem;
      height: 1.75rem;
    }
  }

  /* Reduced motion: stop animation */
  @media (prefers-reduced-motion: reduce) {
    .marquee-wrapper {
      opacity: 1;
      animation: none;
    }

    .shimmer-placeholder {
      display: none;
    }

    .shimmer-card {
      animation: none;
    }

    .marquee-track {
      opacity: 1;
      animation: none;
    }
  }
</style>
