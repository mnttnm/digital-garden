---
/**
 * ImageLightbox Component
 *
 * A modern full-screen image lightbox with:
 * - Smooth open/close animations
 * - Click outside to close
 * - Escape key to close
 * - Arrow key navigation (when multiple images)
 * - Hover zoom hint on thumbnails
 *
 * Usage: Include once in Base.astro, then add data-lightbox to any <img> element
 * For galleries, wrap images in a container with data-lightbox-gallery
 */
---

<div id="image-lightbox" class="lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Image viewer">
  <div class="lightbox-backdrop"></div>

  <button class="lightbox-close" type="button" aria-label="Close image viewer">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <div class="lightbox-content">
    <button class="lightbox-nav lightbox-prev" type="button" aria-label="Previous image" hidden>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <figure class="lightbox-figure">
      <img class="lightbox-image" src="" alt="" />
      <figcaption class="lightbox-caption"></figcaption>
    </figure>

    <button class="lightbox-nav lightbox-next" type="button" aria-label="Next image" hidden>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>

  <div class="lightbox-counter" hidden>
    <span class="lightbox-current">1</span> / <span class="lightbox-total">1</span>
  </div>
</div>

<script>
  // Global state that persists across View Transitions
  interface LightboxState {
    gallery: HTMLImageElement[];
    index: number;
    isOpen: boolean;
    // Function references that get updated on each setup
    close: () => void;
    showPrev: () => void;
    showNext: () => void;
  }

  const state: LightboxState = {
    gallery: [],
    index: 0,
    isOpen: false,
    close: () => {},
    showPrev: () => {},
    showNext: () => {},
  };

  // Track if we've already set up the global keyboard listener
  let keyboardListenerReady = false;

  function setupLightbox() {
    const lightbox = document.getElementById('image-lightbox');
    if (!lightbox) return;

    // Skip if this specific DOM element is already set up
    if (lightbox.dataset.ready === 'true') return;
    lightbox.dataset.ready = 'true';

    const backdrop = lightbox.querySelector('.lightbox-backdrop');
    const closeBtn = lightbox.querySelector('.lightbox-close');
    const prevBtn = lightbox.querySelector('.lightbox-prev') as HTMLButtonElement;
    const nextBtn = lightbox.querySelector('.lightbox-next') as HTMLButtonElement;
    const image = lightbox.querySelector('.lightbox-image') as HTMLImageElement;
    const caption = lightbox.querySelector('.lightbox-caption') as HTMLElement;
    const counter = lightbox.querySelector('.lightbox-counter') as HTMLElement;
    const currentSpan = lightbox.querySelector('.lightbox-current') as HTMLElement;
    const totalSpan = lightbox.querySelector('.lightbox-total') as HTMLElement;

    function open(img: HTMLImageElement, gallery: HTMLImageElement[] = []) {
      state.gallery = gallery.length > 0 ? gallery : [img];
      state.index = state.gallery.indexOf(img);
      if (state.index === -1) state.index = 0;

      updateImage();
      updateNavigation();

      lightbox.setAttribute('aria-hidden', 'false');
      lightbox.classList.add('is-opening');
      document.body.style.overflow = 'hidden';
      state.isOpen = true;

      requestAnimationFrame(() => {
        lightbox.classList.remove('is-opening');
        lightbox.classList.add('is-open');
      });

      setTimeout(() => closeBtn?.focus(), 100);
    }

    function close() {
      if (!state.isOpen) return;

      lightbox.classList.remove('is-open');
      lightbox.classList.add('is-closing');

      setTimeout(() => {
        lightbox.classList.remove('is-closing');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        state.isOpen = false;
        state.gallery = [];
      }, 200);
    }

    function updateImage() {
      const img = state.gallery[state.index];
      if (!img) return;

      const src = img.dataset.lightboxSrc || img.src;
      const alt = img.alt || '';
      const captionText = img.dataset.lightboxCaption || img.closest('figure')?.querySelector('figcaption')?.textContent || '';

      image.src = src;
      image.alt = alt;

      if (captionText) {
        caption.textContent = captionText;
        caption.hidden = false;
      } else {
        caption.hidden = true;
      }

      if (state.gallery.length > 1) {
        currentSpan.textContent = String(state.index + 1);
        totalSpan.textContent = String(state.gallery.length);
        counter.hidden = false;
      } else {
        counter.hidden = true;
      }
    }

    function updateNavigation() {
      const hasMultiple = state.gallery.length > 1;
      prevBtn.hidden = !hasMultiple;
      nextBtn.hidden = !hasMultiple;

      if (hasMultiple) {
        prevBtn.disabled = state.index === 0;
        nextBtn.disabled = state.index === state.gallery.length - 1;
      }
    }

    function showPrev() {
      if (state.index > 0) {
        state.index--;
        updateImage();
        updateNavigation();
      }
    }

    function showNext() {
      if (state.index < state.gallery.length - 1) {
        state.index++;
        updateImage();
        updateNavigation();
      }
    }

    // Store current functions in global state so keyboard handler can access them
    state.close = close;
    state.showPrev = showPrev;
    state.showNext = showNext;

    // DOM event listeners (these are on specific elements, ok to add each time)
    closeBtn?.addEventListener('click', close);
    backdrop?.addEventListener('click', close);
    prevBtn?.addEventListener('click', showPrev);
    nextBtn?.addEventListener('click', showNext);

    // Global keyboard listener (only add once, uses state functions)
    if (!keyboardListenerReady) {
      keyboardListenerReady = true;
      document.addEventListener('keydown', (e) => {
        if (!state.isOpen) return;

        switch (e.key) {
          case 'Escape':
            state.close();
            break;
          case 'ArrowLeft':
            state.showPrev();
            break;
          case 'ArrowRight':
            state.showNext();
            break;
        }
      });

      // Touch swipe support for mobile
      let touchStartX = 0;
      let touchStartY = 0;
      let touchEndX = 0;
      let touchEndY = 0;
      const SWIPE_THRESHOLD = 50;
      const SWIPE_VELOCITY_THRESHOLD = 0.3;
      let touchStartTime = 0;

      document.addEventListener('touchstart', (e) => {
        if (!state.isOpen) return;
        touchStartX = e.changedTouches[0].screenX;
        touchStartY = e.changedTouches[0].screenY;
        touchStartTime = Date.now();
      }, { passive: true });

      document.addEventListener('touchend', (e) => {
        if (!state.isOpen) return;
        touchEndX = e.changedTouches[0].screenX;
        touchEndY = e.changedTouches[0].screenY;

        const deltaX = touchEndX - touchStartX;
        const deltaY = touchEndY - touchStartY;
        const elapsed = Date.now() - touchStartTime;
        const velocity = Math.abs(deltaX) / elapsed;

        // Only trigger if horizontal swipe is dominant and meets threshold
        if (Math.abs(deltaX) > Math.abs(deltaY) &&
            (Math.abs(deltaX) > SWIPE_THRESHOLD || velocity > SWIPE_VELOCITY_THRESHOLD)) {

          const img = document.querySelector('.lightbox-image') as HTMLImageElement;

          if (deltaX > 0 && state.gallery.length > 1 && state.index > 0) {
            img?.classList.add('swipe-right');
            state.showPrev();
            setTimeout(() => img?.classList.remove('swipe-right'), 250);
          } else if (deltaX < 0 && state.gallery.length > 1 && state.index < state.gallery.length - 1) {
            img?.classList.add('swipe-left');
            state.showNext();
            setTimeout(() => img?.classList.remove('swipe-left'), 250);
          }
        }
      }, { passive: true });
    }

    // Initialize clickable images
    function initImages() {
      const imgs = document.querySelectorAll<HTMLImageElement>(
        'img[data-lightbox],' +
        '.entry-thumbnail img,' +
        '.feed-media-item img,' +
        '.capture-image'
      );

      imgs.forEach((img) => {
        if (img.dataset.lightboxInit) return;
        img.dataset.lightboxInit = 'true';
        img.classList.add('lightbox-trigger');

        const container = img.closest('[data-lightbox-gallery], .entry-thumbnails, .feed-media-grid, .capture-images');

        img.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();

          let gallery: HTMLImageElement[] = [];
          if (container) {
            gallery = Array.from(container.querySelectorAll<HTMLImageElement>('img'));
          }
          open(img, gallery);
        });
      });
    }

    initImages();

    // Watch for new images
    const observer = new MutationObserver(() => initImages());
    observer.observe(document.body, { childList: true, subtree: true });
  }

  // Reset overflow before page swap (in case lightbox was open)
  document.addEventListener('astro:before-swap', () => {
    document.body.style.overflow = '';
    state.isOpen = false;
  });

  // Initialize
  setupLightbox();

  // Re-initialize after View Transitions
  document.addEventListener('astro:page-load', () => {
    // Reset lightbox ready state
    const lb = document.getElementById('image-lightbox');
    if (lb) delete lb.dataset.ready;

    // Clear stale lightboxInit from images (View Transitions may preserve them)
    document.querySelectorAll('[data-lightbox-init]').forEach((el) => {
      delete (el as HTMLElement).dataset.lightboxInit;
    });

    setupLightbox();
  });
</script>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
  }

  .lightbox[aria-hidden="false"] {
    pointer-events: auto;
    visibility: visible;
  }

  .lightbox.is-opening,
  .lightbox.is-open {
    opacity: 1;
  }

  .lightbox.is-opening {
    transition: opacity 0.01s;
  }

  .lightbox.is-open {
    transition: opacity 0.2s ease-out;
  }

  .lightbox.is-closing {
    opacity: 0;
    transition: opacity 0.2s ease-out;
  }

  /* Backdrop */
  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .lightbox.is-opening .lightbox-backdrop {
    opacity: 0;
  }

  .lightbox.is-open .lightbox-backdrop {
    opacity: 1;
    transition: opacity 0.25s ease-out;
  }

  /* Close button */
  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 10;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: white;
    cursor: pointer;
    transition: background-color 0.15s ease, transform 0.15s ease;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: scale(1.05);
  }

  .lightbox-close:active {
    transform: scale(0.95);
  }

  /* Content container */
  .lightbox-content {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: 3rem;
  }

  /* Figure & Image */
  .lightbox-figure {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
  }

  .lightbox-image {
    max-width: 100%;
    max-height: calc(100vh - 8rem);
    object-fit: contain;
    border-radius: 0.5rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    transform: scale(0.95);
    opacity: 0;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.25s ease-out;
  }

  .lightbox.is-open .lightbox-image {
    transform: scale(1);
    opacity: 1;
  }

  .lightbox.is-closing .lightbox-image {
    transform: scale(0.95);
    opacity: 0;
    transition: transform 0.2s ease-out, opacity 0.15s ease-out;
  }

  /* Swipe animation classes */
  .lightbox-image.swipe-left {
    animation: swipeLeft 0.25s ease-out;
  }

  .lightbox-image.swipe-right {
    animation: swipeRight 0.25s ease-out;
  }

  @keyframes swipeLeft {
    0% { transform: translateX(0); opacity: 1; }
    50% { transform: translateX(-30px); opacity: 0.7; }
    100% { transform: translateX(0); opacity: 1; }
  }

  @keyframes swipeRight {
    0% { transform: translateX(0); opacity: 1; }
    50% { transform: translateX(30px); opacity: 0.7; }
    100% { transform: translateX(0); opacity: 1; }
  }

  .lightbox-caption {
    margin-top: 1rem;
    padding: 0.5rem 1rem;
    background: rgba(0, 0, 0, 0.6);
    border-radius: 0.5rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.875rem;
    text-align: center;
    max-width: 60ch;
  }

  .lightbox-caption[hidden] {
    display: none;
  }

  /* Navigation buttons */
  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: white;
    cursor: pointer;
    transition: background-color 0.15s ease, transform 0.15s ease, opacity 0.15s ease;
  }

  .lightbox-nav:hover:not(:disabled) {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-50%) scale(1.08);
  }

  .lightbox-nav:active:not(:disabled) {
    transform: translateY(-50%) scale(0.95);
  }

  .lightbox-nav:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .lightbox-nav[hidden] {
    display: none;
  }

  .lightbox-prev {
    left: 1rem;
  }

  .lightbox-next {
    right: 1rem;
  }

  /* Counter */
  .lightbox-counter {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    padding: 0.35rem 0.75rem;
    background: rgba(0, 0, 0, 0.6);
    border-radius: 2rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .lightbox-counter[hidden] {
    display: none;
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .lightbox-content {
      padding: 1rem;
      padding-top: 3.5rem;
      padding-bottom: 3rem;
    }

    .lightbox-figure {
      width: 100%;
      height: 100%;
      justify-content: center;
    }

    .lightbox-image {
      max-width: calc(100vw - 2rem);
      max-height: calc(100vh - 7rem);
      width: auto;
      height: auto;
    }

    .lightbox-nav {
      width: 2.5rem;
      height: 2.5rem;
    }

    .lightbox-prev {
      left: 0.5rem;
    }

    .lightbox-next {
      right: 0.5rem;
    }

    .lightbox-close {
      top: 0.75rem;
      right: 0.75rem;
      width: 2.5rem;
      height: 2.5rem;
    }

    .lightbox-caption {
      margin-top: 0.75rem;
      font-size: 0.8rem;
      padding: 0.4rem 0.75rem;
    }
  }

  /* Very small screens */
  @media (max-width: 400px) {
    .lightbox-content {
      padding: 0.75rem;
      padding-top: 3rem;
      padding-bottom: 2.5rem;
    }

    .lightbox-image {
      max-width: calc(100vw - 1.5rem);
      max-height: calc(100vh - 6rem);
    }

    .lightbox-nav {
      width: 2.25rem;
      height: 2.25rem;
    }

    .lightbox-prev {
      left: 0.25rem;
    }

    .lightbox-next {
      right: 0.25rem;
    }
  }
</style>

<style is:global>
  /* Hover styles for lightbox-triggerable images */
  .lightbox-trigger {
    cursor: zoom-in;
    transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
  }

  .lightbox-trigger:hover {
    transform: scale(1.02);
    box-shadow: 0 8px 25px -8px rgba(0, 0, 0, 0.3);
  }

  /* Entry thumbnail hover enhancement */
  .entry-thumbnail:has(.lightbox-trigger):hover,
  .feed-media-item:has(.lightbox-trigger):hover {
    border-color: var(--accent) !important;
    box-shadow: 0 12px 28px -8px rgba(0, 0, 0, 0.35) !important;
  }

  .entry-thumbnail:has(.lightbox-trigger),
  .feed-media-item:has(.lightbox-trigger) {
    cursor: zoom-in;
  }

  /* Capture card images */
  .capture-image.lightbox-trigger:hover {
    transform: scale(1.02);
    border-color: var(--accent);
  }
</style>
